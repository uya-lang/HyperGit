}

export fn http_remote_default_run_options() EngineRunOptions {
    var options: EngineRunOptions = uyagin_run_options_default();
    options.max_connections = HTTP_REMOTE_DEFAULT_MAX_CONNECTIONS;
    options.read_timeout_ms = HTTP_REMOTE_DEFAULT_READ_TIMEOUT_MS;
    options.write_timeout_ms = HTTP_REMOTE_DEFAULT_WRITE_TIMEOUT_MS;
    options.idle_timeout_ms = HTTP_REMOTE_DEFAULT_IDLE_TIMEOUT_MS;
    return options;
}

export fn http_remote_limits_with_max_body_bytes(max_body_bytes: usize) UyaginLimits {
    var limits: UyaginLimits = uyagin_limits_default();
    var applied: usize = max_body_bytes;
    if applied == 0 as usize {
        applied = MAX_BODY_SIZE as usize;
    }
    limits.max_body_bytes = applied;
    return limits;
}

export fn http_remote_default_limits() UyaginLimits {
    return http_remote_limits_with_max_body_bytes(MAX_BODY_SIZE as usize);
}

export fn http_remote_engine_new() Engine {
    var engine: Engine = uyagin_new();
    const options: EngineRunOptions = http_remote_default_run_options();
    const limits: UyaginLimits = http_remote_default_limits();
    uyagin_set_run_options(&engine, options);
    uyagin_set_limits(&engine, limits);
    return engine;
}

fn http_remote_runtime_new(repo_root: &[byte], default_branch: &[byte], auth_token: &[byte], max_body_bytes: usize) !&HttpRemoteRuntime {
    const raw: &HttpRemoteRuntime = malloc(@size_of(HttpRemoteRuntime) as usize) as &HttpRemoteRuntime;
    if raw == null {
        return error.HttpRemoteAlloc;
    }
    if repo_root.len >= HTTP_REMOTE_PATH_MAX || default_branch.len > 64 as usize {
        free(raw as &void);
        return error.HttpRemoteInvalidBinaryRequest;
    }
    raw.repo_root_len = repo_root.len;
    var i: usize = 0;
    while i < repo_root.len {
        raw.repo_root[i] = repo_root.ptr[i];
        i = i + 1 as usize;
    }
    raw.repo_root[repo_root.len] = 0 as byte;
    raw.default_branch_len = default_branch.len;
    i = 0;
    while i < default_branch.len {
        raw.default_branch[i] = default_branch.ptr[i];
        i = i + 1 as usize;
    }
    raw.max_body_bytes = max_body_bytes;
    raw.auth_token_len = 0 as usize;
    i = 0;
    while i < HTTP_REMOTE_AUTH_TOKEN_MAX {
        raw.auth_token[i] = 0 as byte;
        i = i + 1 as usize;
    }
    if auth_token.len > HTTP_REMOTE_AUTH_TOKEN_MAX {
        free(raw as &void);
        return error.HttpRemoteInvalidBinaryRequest;
    }
    i = 0;
    while i < auth_token.len {
        raw.auth_token[i] = auth_token.ptr[i];
        i = i + 1 as usize;
    }
    raw.auth_token_len = auth_token.len;
    return raw;
}

fn http_remote_register_routes(engine: &Engine, runtime: &HttpRemoteRuntime) !void {
    engine.UseRecovery();
    const auth_handler: AsyncHandler = HttpRemoteAuthHandler{ runtime: runtime };
    const capabilities_handler: AsyncHandler = HttpRemoteCapabilitiesHandler{ runtime: runtime };
    const object_batch_handler: AsyncHandler = HttpRemoteObjectBatchHandler{ runtime: runtime };
    const manifest_query_handler: AsyncHandler = HttpRemoteManifestQueryHandler{ runtime: runtime };
    const fetch_handler: AsyncHandler = HttpRemoteFetchHandler{ runtime: runtime };
    const push_handler: AsyncHandler = HttpRemotePushHandler{ runtime: runtime };
    try engine.Use(auth_handler);
    try engine.GET(http_remote_literal_slice(HTTP_REMOTE_CAPABILITIES_ROUTE), capabilities_handler);
    try engine.POST(http_remote_literal_slice(HTTP_REMOTE_OBJECT_BATCH_ROUTE), object_batch_handler);
    try engine.POST(http_remote_literal_slice(HTTP_REMOTE_MANIFEST_QUERY_ROUTE), manifest_query_handler);
    try engine.POST(http_remote_literal_slice(HTTP_REMOTE_FETCH_ROUTE), fetch_handler);
    try engine.POST(http_remote_literal_slice(HTTP_REMOTE_PUSH_ROUTE), push_handler);
}

export fn http_remote_server_listen_loopback(port: u16) !HttpRemoteServer {
    var engine: Engine = http_remote_engine_new();
    const listener: GinListener = try uyagin_listen_loopback_with_options(port, &engine.run_options);
    return HttpRemoteServer{
        engine: engine,
        listener: listener,
        runtime: null,
    };
}

export fn http_remote_server_listen_loopback_repo(port: u16, repo_root: &[byte], default_branch: &[byte], auth_token: &[byte], max_body_bytes: usize) !HttpRemoteServer {
    var engine: Engine = uyagin_new();
    const options: EngineRunOptions = http_remote_default_run_options();
    const limits: UyaginLimits = http_remote_limits_with_max_body_bytes(max_body_bytes);
    const limit_body_bytes: usize = limits.max_body_bytes;
    uyagin_set_run_options(&engine, options);
    uyagin_set_limits(&engine, limits);

    const runtime: &HttpRemoteRuntime = try http_remote_runtime_new(repo_root, default_branch, auth_token, limit_body_bytes);
    http_remote_register_routes(&engine, runtime) catch |err| {
        free(runtime as &void);
        return err;
    };
    const listener: GinListener = try uyagin_listen_loopback_with_options(port, &engine.run_options);
    return HttpRemoteServer{
        engine: engine,
        listener: listener,
        runtime: runtime,
    };
}

export fn http_remote_server_close(server: &HttpRemoteServer) void {
    if server == null {
        return;
    }
    var http_server: HttpServer = server.listener.server;
    http_server_close(&http_server);
    if server.runtime != null {
        free(server.runtime as &void);
        server.runtime = null;
    }
}

export fn http_remote_server_port(server: &HttpRemoteServer) u16 {
    if server == null {
        return 0 as u16;
    }
    return server.listener.server.port;
}
