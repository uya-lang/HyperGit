use std.runtime.entry;
use std.testing.expect;
use std.testing.run_test;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;

use core.ids.PolicyId;
use core.policy.AuditEventKind;
use core.policy.ExperimentalAuditEvent;
use core.policy.PolicyMetadataDefaults;
use core.policy.experimental_audit_event;
use core.policy.experimental_dedupe_scope;
use core.policy.experimental_policy_defaults;
use core.policy.experimental_policy_id;
use core.policy.policy_id_is_experimental_default;
use object.types.DedupeScope;

fn test_experimental_policy_defaults_are_stable() !void {
    const defaults: PolicyMetadataDefaults = experimental_policy_defaults();
    const policy_id: PolicyId = experimental_policy_id();
    try expect(defaults.experimental);
    try expect(!defaults.audit_enabled);
    try expect(policy_id_is_experimental_default(&policy_id));
    try expect(policy_id_is_experimental_default(&defaults.policy_id));
}

fn test_experimental_dedupe_scope_defaults_to_repository() !void {
    const defaults: PolicyMetadataDefaults = experimental_policy_defaults();
    try expect(defaults.experimental);
    try expect(defaults.dedupe_scope == DedupeScope.Repository);
    try expect(experimental_dedupe_scope() == DedupeScope.Repository);
}

fn test_experimental_audit_event_is_disabled() !void {
    const event: ExperimentalAuditEvent = experimental_audit_event(AuditEventKind.Commit);
    try expect(event.kind == AuditEventKind.Commit);
    try expect(event.experimental);
    try expect(!event.enabled);
    try expect(policy_id_is_experimental_default(&event.policy_id));
    try expect(event.dedupe_scope == DedupeScope.Repository);
}

export fn main() i32 {
    test_suite_begin("HyperGit Policy Metadata Tests");
    run_test("experimental policy defaults are stable", test_experimental_policy_defaults_are_stable);
    run_test("experimental dedupe scope defaults to repository", test_experimental_dedupe_scope_defaults_to_repository);
    run_test("experimental audit event is disabled", test_experimental_audit_event_is_disabled);
    return test_suite_end();
}
