use std.runtime.entry;
use std.testing.expect;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;
use std.mem.arena.Arena;
use std.mem.arena.arena_init;

use libc.system;
use large.chunk_hash.ChunkHashes;
use large.chunk_hash.chunk_hash_plain;
use large.chunk_manifest.ChunkedBlobPart;
use large.chunk_manifest.ChunkedBlobPartList;
use large.chunk_manifest.chunked_blob_part_from_chunk;
use large.chunk_manifest.chunked_blob_part_list_from_slice;
use large.chunk_manifest.chunked_blob_payload_repository_default;
use large.chunk_store.ChunkStore;
use large.chunk_store.ChunkStorePutResult;
use large.chunk_store.chunk_store_open;
use large.chunk_store.chunk_store_put;
use large.chunker.LargeChunk;
use large.chunker.LargeChunkList;
use large.chunker.fixed_chunk_bytes;
use large.range_read.chunked_blob_read_range;
use object.types.ByteList;
use object.types.ChunkedBlobPayload;
use object.types.ChunkingStrategy;
use object.types.FileType;
use object.types.StorageTier;

fn expect_bytes(actual: ByteList, expected: &[byte]) !void {
    try expect(actual.len == expected.len);
    var i: usize = 0 as usize;
    while i < expected.len {
        try expect(actual.ptr[i] == expected.ptr[i]);
        i = i + 1 as usize;
    }
}

fn build_payload(arena: &Arena, store: &ChunkStore, logical: &[byte]) !ChunkedBlobPayload {
    const chunks: LargeChunkList = try fixed_chunk_bytes(arena, logical, 4u32);
    var parts_raw: [ChunkedBlobPart: 3] = [];
    var i: usize = 0 as usize;
    while i < chunks.len {
        const chunk: &LargeChunk = &chunks.ptr[i];
        const hashes: ChunkHashes = try chunk_hash_plain(arena, chunk.bytes.ptr[0: chunk.bytes.len]);
        const stored: ChunkStorePutResult = try chunk_store_put(store, chunk.bytes.ptr[0: chunk.bytes.len]);
        parts_raw[i] = chunked_blob_part_from_chunk(chunk, &hashes, &stored, StorageTier.Hot);
        i = i + 1 as usize;
    }
    const parts: ChunkedBlobPartList = chunked_blob_part_list_from_slice(parts_raw[0: chunks.len]);
    return try chunked_blob_payload_repository_default(arena, logical, FileType.Binary, ChunkingStrategy.Fixed, parts);
}

fn test_chunked_blob_range_read_crosses_chunk_boundaries() !void {
    try expect(system("rm -rf build/range-read-test && mkdir -p build/range-read-test") == 0);
    const store: ChunkStore = try chunk_store_open("build/range-read-test/chunks");

    var logical: [byte: 10] = ['a' as byte, 'b' as byte, 'c' as byte, 'd' as byte, 'e' as byte, 'f' as byte, 'g' as byte, 'h' as byte, 'i' as byte, 'j' as byte];
    var arena_buf: [byte: 16384] = [];
    var arena: Arena = Arena{ buffer: &arena_buf[0], size: 0, used: 0 };
    arena_init(&arena, &arena_buf[0], 16384 as usize);

    const payload: ChunkedBlobPayload = try build_payload(&arena, &store, logical[0: 10]);
    const slice: ByteList = try chunked_blob_read_range(&arena, &store, &payload, 3u64, 5u64);
    try expect_bytes(slice, logical[3: 5]);
}

fn test_chunked_blob_range_read_rejects_invalid_range() !void {
    try expect(system("rm -rf build/range-read-invalid && mkdir -p build/range-read-invalid") == 0);
    const store: ChunkStore = try chunk_store_open("build/range-read-invalid/chunks");

    var logical: [byte: 4] = ['x' as byte, 'y' as byte, 'z' as byte, 'w' as byte];
    var arena_buf: [byte: 8192] = [];
    var arena: Arena = Arena{ buffer: &arena_buf[0], size: 0, used: 0 };
    arena_init(&arena, &arena_buf[0], 8192 as usize);

    const payload: ChunkedBlobPayload = try build_payload(&arena, &store, logical[0: 4]);
    const slice: ByteList = chunked_blob_read_range(&arena, &store, &payload, 2u64, 3u64) catch |err| {
        try expect(@error_id(err) == @error_id(error.LargeRangeInvalidRange));
        return;
    };
    _ = slice;
    return error.AssertionFailed;
}

export fn main() i32 {
    test_suite_begin("HyperGit Large Range Read Tests");
    run_test("chunked blob range read crosses chunk boundaries", test_chunked_blob_range_read_crosses_chunk_boundaries);
    run_test("chunked blob range read rejects invalid range", test_chunked_blob_range_read_rejects_invalid_range);
    return test_suite_end();
}
