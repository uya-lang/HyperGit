use std.runtime.entry;
use std.testing.expect;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;
use std.mem.arena.Arena;
use std.mem.arena.arena_alloc;
use std.mem.arena.arena_init;

use libc.Stat;
use libc.stat;
use libc.system;
use std.crypto.crc32.crc32_compute;
use std.io.file.FILE;
use std.io.file.fclose;
use std.io.file.fopen;
use std.io.file.fread;
use std.io.file.fwrite;
use core.codec.codec_decode_hash32;
use core.codec.codec_hash_payload;
use core.codec.codec_decode_i64;
use core.codec.codec_decode_u16;
use core.codec.codec_decode_u32;
use core.codec.codec_decode_u64;
use core.ids.Hash32;
use core.ids.ObjectId;
use core.ids.hash32_compare;
use core.ids.object_id_compare;
use object.types.ByteList;
use object.types.ObjectKind;
use object.types.object_kind_to_u16;
use store.loose_store.LooseObjectStore;
use store.loose_store.loose_store_open;
use store.object_store.ObjectBytes;
use store.segment_pack.PACK_INDEX_ENTRY_BYTES;
use store.segment_pack.PACK_INDEX_FOOTER_BYTES;
use store.segment_pack.PACK_INDEX_HEADER_BYTES;
use store.segment_pack.PACK_INDEX_MAGIC;
use store.segment_pack.PACK_INDEX_VERSION;
use store.segment_pack.SEGMENT_PACK_FOOTER_BYTES;
use store.segment_pack.SEGMENT_PACK_HEADER_BYTES;
use store.segment_pack.SEGMENT_PACK_MAGIC;
use store.segment_pack.SEGMENT_PACK_RECORD_HEADER_BYTES;
use store.segment_pack.SEGMENT_PACK_RECORD_TRAILER_BYTES;
use store.segment_pack.SEGMENT_PACK_VERSION;
use store.segment_pack.SegmentPackWriteInput;
use store.segment_pack.SegmentPackWriteResult;
use store.segment_pack.SegmentPackSnapshot;
use store.segment_pack.SegmentPackIndexEntry;
use store.segment_pack.SegmentPackIndexSnapshot;
use store.segment_pack.segment_pack_index_read;
use store.segment_pack.segment_pack_index_lookup;
use store.segment_pack.segment_pack_read;
use store.segment_pack.segment_pack_write;
use store.segment_pack.loose_pack_compact;
use store.segment_pack.CompactionResult;

struct ExpectedIndexEntry {
    object_id: ObjectId,
    record_offset: u64,
    record_bytes: u32,
    kind: u16,
    flags: u16,
    logical_size: u64
}

fn segment_pack_test_arena_bytes(arena: &Arena, len: usize) !&[byte] {
    var want: usize = len;
    if want == 0 as usize {
        want = 1 as usize;
    }
    const raw: &byte = arena_alloc(arena, want);
    if raw == null {
        return error.AssertionFailed;
    }
    return raw[0: len];
}

fn segment_pack_test_load_file_bytes(path: &const byte, arena: &Arena) !ByteList {
    var st: Stat = Stat{};
    try expect(stat(path, &st) == 0);
    const size: usize = st.st_size as usize;
    const output: &[byte] = try segment_pack_test_arena_bytes(arena, size);
    const stream: &FILE = fopen(path, "r");
    try expect(stream != null);
    defer {
        _ = fclose(stream);
    }
    try expect(fread(output.ptr, 1 as usize, size, stream) == size);
    return ByteList{ ptr: output.ptr, len: size };
}

fn segment_pack_test_expect_bytes_eq(actual: &[byte], expected: ByteList) !void {
    try expect(actual.len == expected.len);
    var i: usize = 0 as usize;
    while i < expected.len {
        try expect(actual.ptr[i] == expected.ptr[i]);
        i = i + 1 as usize;
    }
}

fn segment_pack_test_expect_zero_hash(hash: Hash32) !void {
    const zero: Hash32 = Hash32{ bytes: [] };
    try expect(hash32_compare(&hash, &zero) == 0);
}

fn segment_pack_test_hash_with_zero_region(arena: &Arena, input: &[byte], zero_offset: usize, zero_len: usize) !Hash32 {
    const copy: &[byte] = try segment_pack_test_arena_bytes(arena, input.len);
    var i: usize = 0 as usize;
    while i < input.len {
        copy.ptr[i] = input.ptr[i];
        i = i + 1 as usize;
    }
    i = 0 as usize;
    while i < zero_len {
        copy.ptr[zero_offset + i] = 0 as byte;
        i = i + 1 as usize;
    }
    return codec_hash_payload(copy);
}

fn segment_pack_test_hash_footer_cross_ref(arena: &Arena, input: &[byte], zero_offset: usize) !Hash32 {
    const copy: &[byte] = try segment_pack_test_arena_bytes(arena, input.len);
    var i: usize = 0 as usize;
    while i < input.len {
        copy.ptr[i] = input.ptr[i];
        i = i + 1 as usize;
    }
    i = 0 as usize;
    while i < 32 as usize {
        copy.ptr[zero_offset + i] = 0 as byte;
        i = i + 1 as usize;
    }
    const footer_crc_offset: usize = input.len - 4 as usize;
    i = 0 as usize;
    while i < 4 as usize {
        copy.ptr[footer_crc_offset + i] = 0 as byte;
        i = i + 1 as usize;
    }
    return codec_hash_payload(copy);
}

fn segment_pack_test_expected_record_bytes(record: &SegmentPackWriteInput) u32 {
    return (SEGMENT_PACK_RECORD_HEADER_BYTES + record.object_bytes.len + SEGMENT_PACK_RECORD_TRAILER_BYTES) as u32;
}

fn test_segment_pack_writer_roundtrip_layout() !void {
    try expect(system("rm -rf build/segment-pack-test && mkdir -p build/segment-pack-test/objects/loose build/segment-pack-test/packs") == 0);

    const store: LooseObjectStore = try loose_store_open("build/segment-pack-test/objects/loose");

    var payload_a: [byte: 5] = ['a' as byte, 'l' as byte, 'p' as byte, 'h' as byte, 'a' as byte];
    var payload_b: [byte: 4] = ['b' as byte, 'e' as byte, 't' as byte, 'a' as byte];
    const id_a: ObjectId = try store.put(ObjectKind.Commit, payload_a[0: 5]);
    const id_b: ObjectId = try store.put(ObjectKind.Commit, payload_b[0: 4]);

    var object_arena_buf: [byte: 16384] = [];
    var object_arena: Arena = Arena{ buffer: &object_arena_buf[0], size: 0, used: 0 };
    arena_init(&object_arena, &object_arena_buf[0], 16384 as usize);
    const bytes_a: ObjectBytes = try store.get(ObjectId{ hash: id_a.hash }, &object_arena);
    const bytes_b: ObjectBytes = try store.get(ObjectId{ hash: id_b.hash }, &object_arena);

    var inputs: [SegmentPackWriteInput: 2] = [
        SegmentPackWriteInput{
            object_id: ObjectId{ hash: id_a.hash },
            kind: ObjectKind.Commit,
            flags: 0u16,
            logical_size: bytes_a.bytes.len as u64,
            object_bytes: ByteList{ ptr: bytes_a.bytes.ptr, len: bytes_a.bytes.len },
        },
        SegmentPackWriteInput{
            object_id: ObjectId{ hash: id_b.hash },
            kind: ObjectKind.Commit,
            flags: 7u16,
            logical_size: bytes_b.bytes.len as u64,
            object_bytes: ByteList{ ptr: bytes_b.bytes.ptr, len: bytes_b.bytes.len },
        },
    ];
    if object_id_compare(&id_a, &id_b) < 0 {
        inputs[0] = SegmentPackWriteInput{
            object_id: ObjectId{ hash: id_b.hash },
            kind: ObjectKind.Commit,
            flags: 7u16,
            logical_size: bytes_b.bytes.len as u64,
            object_bytes: ByteList{ ptr: bytes_b.bytes.ptr, len: bytes_b.bytes.len },
        };
        inputs[1] = SegmentPackWriteInput{
            object_id: ObjectId{ hash: id_a.hash },
            kind: ObjectKind.Commit,
            flags: 0u16,
            logical_size: bytes_a.bytes.len as u64,
            object_bytes: ByteList{ ptr: bytes_a.bytes.ptr, len: bytes_a.bytes.len },
        };
    }

    const result: SegmentPackWriteResult = try segment_pack_write(
        "build/segment-pack-test/packs/seg-000001.hgp",
        "build/segment-pack-test/packs/seg-000001.hgi",
        1u64,
        1234i64,
        9u64,
        inputs[0: 2],
    );

    const first_record_bytes: u32 = segment_pack_test_expected_record_bytes(&inputs[0]);
    const second_record_bytes: u32 = segment_pack_test_expected_record_bytes(&inputs[1]);
    try expect(result.object_count == 2u64);
    try expect(result.data_bytes == first_record_bytes as u64 + second_record_bytes as u64);
    try expect(result.pack_bytes == SEGMENT_PACK_HEADER_BYTES as u64 + result.data_bytes + SEGMENT_PACK_FOOTER_BYTES as u64);
    try expect(result.index_bytes == PACK_INDEX_HEADER_BYTES as u64 + 2u64 * PACK_INDEX_ENTRY_BYTES as u64 + PACK_INDEX_FOOTER_BYTES as u64);
    try expect(result.pack_footer_offset == SEGMENT_PACK_HEADER_BYTES as u64 + result.data_bytes);
    try expect(result.index_footer_offset == PACK_INDEX_HEADER_BYTES as u64 + 2u64 * PACK_INDEX_ENTRY_BYTES as u64);

    var file_arena_buf: [byte: 32768] = [];
    var file_arena: Arena = Arena{ buffer: &file_arena_buf[0], size: 0, used: 0 };
    arena_init(&file_arena, &file_arena_buf[0], 32768 as usize);
    const pack_bytes: ByteList = try segment_pack_test_load_file_bytes("build/segment-pack-test/packs/seg-000001.hgp", &file_arena);
    const index_bytes: ByteList = try segment_pack_test_load_file_bytes("build/segment-pack-test/packs/seg-000001.hgi", &file_arena);
    const expected_pack_hash: Hash32 = try segment_pack_test_hash_footer_cross_ref(
        &file_arena,
        pack_bytes.ptr[0: pack_bytes.len],
        result.pack_footer_offset as usize + 8 as usize,
    );
    const expected_index_hash: Hash32 = try segment_pack_test_hash_footer_cross_ref(
        &file_arena,
        index_bytes.ptr[0: index_bytes.len],
        result.index_footer_offset as usize,
    );
    const expected_entries_hash: Hash32 = codec_hash_payload(index_bytes.ptr[PACK_INDEX_HEADER_BYTES: result.index_footer_offset as usize - PACK_INDEX_HEADER_BYTES]);

    try expect(pack_bytes.len == result.pack_bytes as usize);
    try expect(index_bytes.len == result.index_bytes as usize);

    var pack_offset: usize = 0 as usize;
    try expect(try codec_decode_u32(pack_bytes.ptr[0: pack_bytes.len], &pack_offset) == SEGMENT_PACK_MAGIC);
    try expect(try codec_decode_u16(pack_bytes.ptr[0: pack_bytes.len], &pack_offset) == SEGMENT_PACK_VERSION);
    try expect(try codec_decode_u16(pack_bytes.ptr[0: pack_bytes.len], &pack_offset) == SEGMENT_PACK_HEADER_BYTES as u16);
    try expect(try codec_decode_u64(pack_bytes.ptr[0: pack_bytes.len], &pack_offset) == 1u64);
    try expect(try codec_decode_u64(pack_bytes.ptr[0: pack_bytes.len], &pack_offset) == 2u64);
    try expect(try codec_decode_u64(pack_bytes.ptr[0: pack_bytes.len], &pack_offset) == result.data_bytes);
    try expect(try codec_decode_u64(pack_bytes.ptr[0: pack_bytes.len], &pack_offset) == result.pack_footer_offset);
    try expect(try codec_decode_i64(pack_bytes.ptr[0: pack_bytes.len], &pack_offset) == 1234i64);
    try expect(try codec_decode_u64(pack_bytes.ptr[0: pack_bytes.len], &pack_offset) == 9u64);
    try expect(try codec_decode_u32(pack_bytes.ptr[0: pack_bytes.len], &pack_offset) == 0u32);
    const pack_header_crc: u32 = try codec_decode_u32(pack_bytes.ptr[0: pack_bytes.len], &pack_offset);
    try expect(pack_header_crc == crc32_compute(pack_bytes.ptr[0: SEGMENT_PACK_HEADER_BYTES - 4 as usize]));
    try expect(pack_offset == SEGMENT_PACK_HEADER_BYTES);

    const first_record_offset: usize = pack_offset;
    try expect(try codec_decode_u32(pack_bytes.ptr[0: pack_bytes.len], &pack_offset) == first_record_bytes);
    try expect(try codec_decode_u16(pack_bytes.ptr[0: pack_bytes.len], &pack_offset) == object_kind_to_u16(inputs[0].kind));
    try expect(try codec_decode_u16(pack_bytes.ptr[0: pack_bytes.len], &pack_offset) == inputs[0].flags);
    try expect(object_id_compare(&ObjectId{ hash: try codec_decode_hash32(pack_bytes.ptr[0: pack_bytes.len], &pack_offset) }, &inputs[0].object_id) == 0);
    const first_payload_crc: u32 = try codec_decode_u32(pack_bytes.ptr[0: pack_bytes.len], &pack_offset);
    try expect(first_payload_crc == crc32_compute(inputs[0].object_bytes.ptr[0: inputs[0].object_bytes.len]));
    try segment_pack_test_expect_bytes_eq(pack_bytes.ptr[pack_offset: inputs[0].object_bytes.len], inputs[0].object_bytes);
    pack_offset = pack_offset + inputs[0].object_bytes.len;
    try expect(try codec_decode_u32(pack_bytes.ptr[0: pack_bytes.len], &pack_offset) == crc32_compute(pack_bytes.ptr[first_record_offset: first_record_bytes as usize - SEGMENT_PACK_RECORD_TRAILER_BYTES]));

    const second_record_offset: usize = pack_offset;
    try expect(try codec_decode_u32(pack_bytes.ptr[0: pack_bytes.len], &pack_offset) == second_record_bytes);
    try expect(try codec_decode_u16(pack_bytes.ptr[0: pack_bytes.len], &pack_offset) == object_kind_to_u16(inputs[1].kind));
    try expect(try codec_decode_u16(pack_bytes.ptr[0: pack_bytes.len], &pack_offset) == inputs[1].flags);
    try expect(object_id_compare(&ObjectId{ hash: try codec_decode_hash32(pack_bytes.ptr[0: pack_bytes.len], &pack_offset) }, &inputs[1].object_id) == 0);
    const second_payload_crc: u32 = try codec_decode_u32(pack_bytes.ptr[0: pack_bytes.len], &pack_offset);
    try expect(second_payload_crc == crc32_compute(inputs[1].object_bytes.ptr[0: inputs[1].object_bytes.len]));
    try segment_pack_test_expect_bytes_eq(pack_bytes.ptr[pack_offset: inputs[1].object_bytes.len], inputs[1].object_bytes);
    pack_offset = pack_offset + inputs[1].object_bytes.len;
    try expect(try codec_decode_u32(pack_bytes.ptr[0: pack_bytes.len], &pack_offset) == crc32_compute(pack_bytes.ptr[second_record_offset: second_record_bytes as usize - SEGMENT_PACK_RECORD_TRAILER_BYTES]));

    try expect(pack_offset == result.pack_footer_offset as usize);
    try expect(try codec_decode_u64(pack_bytes.ptr[0: pack_bytes.len], &pack_offset) == 1u64);
    const pack_footer_index_hash: Hash32 = try codec_decode_hash32(pack_bytes.ptr[0: pack_bytes.len], &pack_offset);
    try expect(hash32_compare(&pack_footer_index_hash, &expected_index_hash) == 0);
    try expect(try codec_decode_u32(pack_bytes.ptr[0: pack_bytes.len], &pack_offset) == 0u32);
    try expect(try codec_decode_u32(pack_bytes.ptr[0: pack_bytes.len], &pack_offset) == crc32_compute(pack_bytes.ptr[result.pack_footer_offset as usize: SEGMENT_PACK_FOOTER_BYTES - 4 as usize]));
    try expect(pack_offset == pack_bytes.len);

    var expected_entries: [ExpectedIndexEntry: 2] = [
        ExpectedIndexEntry{
            object_id: inputs[0].object_id,
            record_offset: first_record_offset as u64,
            record_bytes: first_record_bytes,
            kind: object_kind_to_u16(inputs[0].kind),
            flags: inputs[0].flags,
            logical_size: inputs[0].logical_size,
        },
        ExpectedIndexEntry{
            object_id: inputs[1].object_id,
            record_offset: second_record_offset as u64,
            record_bytes: second_record_bytes,
            kind: object_kind_to_u16(inputs[1].kind),
            flags: inputs[1].flags,
            logical_size: inputs[1].logical_size,
        },
    ];
    if object_id_compare(&expected_entries[0].object_id, &expected_entries[1].object_id) > 0 {
        const temp: ExpectedIndexEntry = expected_entries[0];
        expected_entries[0] = expected_entries[1];
        expected_entries[1] = temp;
    }

    var index_offset: usize = 0 as usize;
    try expect(try codec_decode_u32(index_bytes.ptr[0: index_bytes.len], &index_offset) == PACK_INDEX_MAGIC);
    try expect(try codec_decode_u16(index_bytes.ptr[0: index_bytes.len], &index_offset) == PACK_INDEX_VERSION);
    try expect(try codec_decode_u16(index_bytes.ptr[0: index_bytes.len], &index_offset) == PACK_INDEX_HEADER_BYTES as u16);
    try expect(try codec_decode_u64(index_bytes.ptr[0: index_bytes.len], &index_offset) == 1u64);
    try expect(try codec_decode_u64(index_bytes.ptr[0: index_bytes.len], &index_offset) == 2u64);
    try expect(try codec_decode_u64(index_bytes.ptr[0: index_bytes.len], &index_offset) == PACK_INDEX_HEADER_BYTES as u64);
    try expect(try codec_decode_u64(index_bytes.ptr[0: index_bytes.len], &index_offset) == result.index_footer_offset);
    const index_header_crc: u32 = try codec_decode_u32(index_bytes.ptr[0: index_bytes.len], &index_offset);
    try expect(index_header_crc == crc32_compute(index_bytes.ptr[0: PACK_INDEX_HEADER_BYTES - 8 as usize]));
    try expect(try codec_decode_u32(index_bytes.ptr[0: index_bytes.len], &index_offset) == 0u32);
    try expect(index_offset == PACK_INDEX_HEADER_BYTES);

    var entry_index: usize = 0 as usize;
    while entry_index < 2 as usize {
        const expected: &ExpectedIndexEntry = &expected_entries[entry_index];
        try expect(object_id_compare(&ObjectId{ hash: try codec_decode_hash32(index_bytes.ptr[0: index_bytes.len], &index_offset) }, &expected.object_id) == 0);
        try expect(try codec_decode_u64(index_bytes.ptr[0: index_bytes.len], &index_offset) == expected.record_offset);
        try expect(try codec_decode_u32(index_bytes.ptr[0: index_bytes.len], &index_offset) == expected.record_bytes);
        try expect(try codec_decode_u16(index_bytes.ptr[0: index_bytes.len], &index_offset) == expected.kind);
        try expect(try codec_decode_u16(index_bytes.ptr[0: index_bytes.len], &index_offset) == expected.flags);
        try expect(try codec_decode_u64(index_bytes.ptr[0: index_bytes.len], &index_offset) == expected.logical_size);
        try expect(try codec_decode_u32(index_bytes.ptr[0: index_bytes.len], &index_offset) == 0u32);
        try expect(try codec_decode_u32(index_bytes.ptr[0: index_bytes.len], &index_offset) == crc32_compute(index_bytes.ptr[PACK_INDEX_HEADER_BYTES + (entry_index * PACK_INDEX_ENTRY_BYTES): PACK_INDEX_ENTRY_BYTES - 4 as usize]));
        entry_index = entry_index + 1 as usize;
    }

    try expect(index_offset == result.index_footer_offset as usize);
    const index_footer_pack_hash: Hash32 = try codec_decode_hash32(index_bytes.ptr[0: index_bytes.len], &index_offset);
    try expect(hash32_compare(&index_footer_pack_hash, &expected_pack_hash) == 0);
    const index_footer_entries_hash: Hash32 = try codec_decode_hash32(index_bytes.ptr[0: index_bytes.len], &index_offset);
    try expect(hash32_compare(&index_footer_entries_hash, &expected_entries_hash) == 0);
    try expect(try codec_decode_u32(index_bytes.ptr[0: index_bytes.len], &index_offset) == 0u32);
    try expect(try codec_decode_u32(index_bytes.ptr[0: index_bytes.len], &index_offset) == crc32_compute(index_bytes.ptr[result.index_footer_offset as usize: PACK_INDEX_FOOTER_BYTES - 4 as usize]));
    try expect(index_offset == index_bytes.len);

    var index_read_arena_buf: [byte: 32768] = [];
    var index_read_arena: Arena = Arena{ buffer: &index_read_arena_buf[0], size: 0, used: 0 };
    arena_init(&index_read_arena, &index_read_arena_buf[0], 32768 as usize);
    const index_snapshot: SegmentPackIndexSnapshot = try segment_pack_index_read("build/segment-pack-test/packs/seg-000001.hgi", &index_read_arena);
    try expect(index_snapshot.header.segment_seq == 1u64);
    try expect(index_snapshot.header.entry_count == 2u64);
    try expect(index_snapshot.header.entries_offset == PACK_INDEX_HEADER_BYTES as u64);
    try expect(index_snapshot.header.bloom_offset == result.index_footer_offset);
    try expect(index_snapshot.bloom_block.len == 0 as usize);
    try expect(hash32_compare(&index_snapshot.footer.pack_hash, &expected_pack_hash) == 0);
    try expect(hash32_compare(&index_snapshot.footer.entries_hash, &expected_entries_hash) == 0);
    try expect(index_snapshot.footer.footer_crc32 == crc32_compute(index_bytes.ptr[result.index_footer_offset as usize: PACK_INDEX_FOOTER_BYTES - 4 as usize]));

    var read_arena_buf: [byte: 32768] = [];
    var read_arena: Arena = Arena{ buffer: &read_arena_buf[0], size: 0, used: 0 };
    arena_init(&read_arena, &read_arena_buf[0], 32768 as usize);
    const snapshot: SegmentPackSnapshot = try segment_pack_read("build/segment-pack-test/packs/seg-000001.hgp", &read_arena);
    try expect(snapshot.header.segment_seq == 1u64);
    try expect(snapshot.header.object_count == 2u64);
    try expect(snapshot.header.data_bytes == result.data_bytes);
    try expect(snapshot.header.index_ref_offset == result.pack_footer_offset);
    try expect(snapshot.header.created_at_ms == 1234i64);
    try expect(snapshot.header.base_generation == 9u64);
    try expect(snapshot.records.len == 2 as usize);
    try expect(snapshot.records.ptr[0].record_offset == first_record_offset as u64);
    try expect(snapshot.records.ptr[0].record_bytes == first_record_bytes);
    try expect(snapshot.records.ptr[0].kind == inputs[0].kind);
    try expect(snapshot.records.ptr[0].flags == inputs[0].flags);
    try expect(object_id_compare(&snapshot.records.ptr[0].object_id, &inputs[0].object_id) == 0);
    try expect(snapshot.records.ptr[0].payload_crc32 == crc32_compute(inputs[0].object_bytes.ptr[0: inputs[0].object_bytes.len]));
    try expect(snapshot.records.ptr[0].trailer_crc32 == crc32_compute(pack_bytes.ptr[first_record_offset: first_record_bytes as usize - SEGMENT_PACK_RECORD_TRAILER_BYTES]));
    try segment_pack_test_expect_bytes_eq(snapshot.records.ptr[0].object_bytes.ptr[0: snapshot.records.ptr[0].object_bytes.len], inputs[0].object_bytes);
    try expect(snapshot.records.ptr[1].record_offset == second_record_offset as u64);
    try expect(snapshot.records.ptr[1].record_bytes == second_record_bytes);
    try expect(snapshot.records.ptr[1].kind == inputs[1].kind);
    try expect(snapshot.records.ptr[1].flags == inputs[1].flags);
    try expect(object_id_compare(&snapshot.records.ptr[1].object_id, &inputs[1].object_id) == 0);
    try expect(snapshot.records.ptr[1].payload_crc32 == crc32_compute(inputs[1].object_bytes.ptr[0: inputs[1].object_bytes.len]));
    try expect(snapshot.records.ptr[1].trailer_crc32 == crc32_compute(pack_bytes.ptr[second_record_offset: second_record_bytes as usize - SEGMENT_PACK_RECORD_TRAILER_BYTES]));
    try segment_pack_test_expect_bytes_eq(snapshot.records.ptr[1].object_bytes.ptr[0: snapshot.records.ptr[1].object_bytes.len], inputs[1].object_bytes);
    try expect(snapshot.footer.segment_seq == 1u64);
    try expect(hash32_compare(&snapshot.footer.index_hash, &expected_index_hash) == 0);
    try expect(snapshot.footer.footer_crc32 == crc32_compute(pack_bytes.ptr[result.pack_footer_offset as usize: SEGMENT_PACK_FOOTER_BYTES - 4 as usize]));

    var lookup_arena_buf: [byte: 32768] = [];
    var lookup_arena: Arena = Arena{ buffer: &lookup_arena_buf[0], size: 0, used: 0 };
    arena_init(&lookup_arena, &lookup_arena_buf[0], 32768 as usize);
    const found_entry: SegmentPackIndexEntry = try segment_pack_index_lookup("build/segment-pack-test/packs/seg-000001.hgi", ObjectId{ hash: expected_entries[0].object_id.hash }, &lookup_arena);
    try expect(object_id_compare(&found_entry.object_id, &expected_entries[0].object_id) == 0);
    try expect(found_entry.record_offset == expected_entries[0].record_offset);
    try expect(found_entry.record_bytes == expected_entries[0].record_bytes);
    try expect(found_entry.kind == inputs[0].kind || found_entry.kind == inputs[1].kind);

    var missing_hash: Hash32 = expected_entries[0].object_id.hash;
    missing_hash.bytes[0] = missing_hash.bytes[0] ^ 0xff as byte;
    const missing_entry: SegmentPackIndexEntry = segment_pack_index_lookup("build/segment-pack-test/packs/seg-000001.hgi", ObjectId{ hash: missing_hash }, &lookup_arena) catch |err| {
        try expect(@error_id(err) == @error_id(error.SegmentPackObjectNotFound));
        return;
    };
    _ = missing_entry;
    return error.AssertionFailed;
}

fn test_segment_pack_writer_rejects_duplicate_object_ids() !void {
    try expect(system("rm -rf build/segment-pack-duplicate && mkdir -p build/segment-pack-duplicate/objects/loose build/segment-pack-duplicate/packs") == 0);

    const store: LooseObjectStore = try loose_store_open("build/segment-pack-duplicate/objects/loose");
    var payload: [byte: 9] = ['d' as byte, 'u' as byte, 'p' as byte, 'l' as byte, 'i' as byte, 'c' as byte, 'a' as byte, 't' as byte, 'e' as byte];
    const id: ObjectId = try store.put(ObjectKind.Commit, payload[0: 9]);

    var arena_buf: [byte: 8192] = [];
    var arena: Arena = Arena{ buffer: &arena_buf[0], size: 0, used: 0 };
    arena_init(&arena, &arena_buf[0], 8192 as usize);
    const bytes: ObjectBytes = try store.get(ObjectId{ hash: id.hash }, &arena);

    const input: SegmentPackWriteInput = SegmentPackWriteInput{
        object_id: ObjectId{ hash: id.hash },
        kind: ObjectKind.Commit,
        flags: 0u16,
        logical_size: bytes.bytes.len as u64,
        object_bytes: ByteList{ ptr: bytes.bytes.ptr, len: bytes.bytes.len },
    };
    var inputs: [SegmentPackWriteInput: 2] = [input, input];

    const write_result: SegmentPackWriteResult = segment_pack_write(
        "build/segment-pack-duplicate/packs/seg-000001.hgp",
        "build/segment-pack-duplicate/packs/seg-000001.hgi",
        1u64,
        0i64,
        0u64,
        inputs[0: 2],
    ) catch |err| {
        try expect(@error_id(err) == @error_id(error.SegmentPackDuplicateObjectId));
        return;
    };
    _ = write_result;
    return error.AssertionFailed;
}

fn test_segment_pack_reader_rejects_corrupt_record_bytes() !void {
    try expect(system("rm -rf build/segment-pack-corrupt && mkdir -p build/segment-pack-corrupt/objects/loose build/segment-pack-corrupt/packs") == 0);

    const store: LooseObjectStore = try loose_store_open("build/segment-pack-corrupt/objects/loose");
    var payload: [byte: 7] = ['c' as byte, 'o' as byte, 'r' as byte, 'r' as byte, 'u' as byte, 'p' as byte, 't' as byte];
    const id: ObjectId = try store.put(ObjectKind.Commit, payload[0: 7]);

    var arena_buf: [byte: 8192] = [];
    var arena: Arena = Arena{ buffer: &arena_buf[0], size: 0, used: 0 };
    arena_init(&arena, &arena_buf[0], 8192 as usize);
    const bytes: ObjectBytes = try store.get(ObjectId{ hash: id.hash }, &arena);

    var inputs: [SegmentPackWriteInput: 1] = [
        SegmentPackWriteInput{
            object_id: ObjectId{ hash: id.hash },
            kind: ObjectKind.Commit,
            flags: 0u16,
            logical_size: bytes.bytes.len as u64,
            object_bytes: ByteList{ ptr: bytes.bytes.ptr, len: bytes.bytes.len },
        },
    ];
    _ = try segment_pack_write(
        "build/segment-pack-corrupt/packs/seg-000001.hgp",
        "build/segment-pack-corrupt/packs/seg-000001.hgi",
        1u64,
        0i64,
        0u64,
        inputs[0: 1],
    );
    try expect(system("printf '!' | dd of=build/segment-pack-corrupt/packs/seg-000001.hgp bs=1 seek=108 conv=notrunc status=none") == 0);

    var read_arena_buf: [byte: 8192] = [];
    var read_arena: Arena = Arena{ buffer: &read_arena_buf[0], size: 0, used: 0 };
    arena_init(&read_arena, &read_arena_buf[0], 8192 as usize);
    const snapshot: SegmentPackSnapshot = segment_pack_read("build/segment-pack-corrupt/packs/seg-000001.hgp", &read_arena) catch |err| {
        try expect(@error_id(err) == @error_id(error.SegmentPackInvalid));
        return;
    };
    _ = snapshot;
    return error.AssertionFailed;
}

fn test_segment_pack_reader_rejects_corrupt_footer_bytes() !void {
    try expect(system("rm -rf build/segment-pack-footer && mkdir -p build/segment-pack-footer/objects/loose build/segment-pack-footer/packs") == 0);

    const store: LooseObjectStore = try loose_store_open("build/segment-pack-footer/objects/loose");
