        0i64,
        0u64,
        inputs[0: 1],
    );
    try expect(system("python3 -c \"from pathlib import Path; p = Path('build/segment-pack-footer/packs/seg-000001.hgp'); data = bytearray(p.read_bytes()); data[-8] = ord('!'); p.write_bytes(data)\"") == 0);

    var read_arena_buf: [byte: 8192] = [];
    var read_arena: Arena = Arena{ buffer: &read_arena_buf[0], size: 0, used: 0 };
