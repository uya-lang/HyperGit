    var arena_buf: [byte: 8192] = [];
    var arena: Arena = Arena{ buffer: &arena_buf[0], size: 0, used: 0 };
    arena_init(&arena, &arena_buf[0], 8192 as usize);
    const bytes: ObjectBytes = try store.get(ObjectId{ hash: id.hash }, &arena);

    var inputs: [SegmentPackWriteInput: 1] = [
        SegmentPackWriteInput{
            object_id: ObjectId{ hash: id.hash },
            kind: ObjectKind.Commit,
            flags: 0u16,
            logical_size: bytes.bytes.len as u64,
            object_bytes: ByteList{ ptr: bytes.bytes.ptr, len: bytes.bytes.len },
        },
    ];
    _ = try segment_pack_write(
        "build/segment-pack-footer/packs/seg-000001.hgp",
        "build/segment-pack-footer/packs/seg-000001.hgi",
