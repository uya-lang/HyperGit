        try expect(@error_id(err) == @error_id(error.SegmentPackInvalid));
        return;
    };
    _ = snapshot;
    return error.AssertionFailed;
}

fn test_segment_pack_reader_rejects_object_hash_mismatch_with_valid_crcs() !void {
    try expect(system("rm -rf build/segment-pack-object-hash && mkdir -p build/segment-pack-object-hash/objects/loose build/segment-pack-object-hash/packs") == 0);

    const store: LooseObjectStore = try loose_store_open("build/segment-pack-object-hash/objects/loose");
    var payload: [byte: 5] = ['h' as byte, 'a' as byte, 's' as byte, 'h' as byte, '!' as byte];
    const id: ObjectId = try store.put(ObjectKind.Commit, payload[0: 5]);

    var arena_buf: [byte: 8192] = [];
    var arena: Arena = Arena{ buffer: &arena_buf[0], size: 0, used: 0 };
    arena_init(&arena, &arena_buf[0], 8192 as usize);
    const bytes: ObjectBytes = try store.get(ObjectId{ hash: id.hash }, &arena);

    var inputs: [SegmentPackWriteInput: 1] = [
        SegmentPackWriteInput{
            object_id: ObjectId{ hash: id.hash },
            kind: ObjectKind.Commit,
            flags: 0u16,
            logical_size: bytes.bytes.len as u64,
            object_bytes: ByteList{ ptr: bytes.bytes.ptr, len: bytes.bytes.len },
        },
    ];
    _ = try segment_pack_write(
        "build/segment-pack-object-hash/packs/seg-000001.hgp",
        "build/segment-pack-object-hash/packs/seg-000001.hgi",
        1u64,
        0i64,
        0u64,
        inputs[0: 1],
    );

    try expect(system("python3 -c \"from pathlib import Path; import zlib; p = Path('build/segment-pack-object-hash/packs/seg-000001.hgp'); data = bytearray(p.read_bytes()); record_start = 64; record_bytes = int.from_bytes(data[record_start:record_start+4], 'little'); payload_crc_offset = record_start + 40; object_offset = record_start + 44; object_len = record_bytes - 44 - 4; data[object_offset + object_len - 1] ^= 0x01; payload_crc = zlib.crc32(data[object_offset:object_offset+object_len]) & 0xffffffff; data[payload_crc_offset:payload_crc_offset+4] = payload_crc.to_bytes(4, 'little'); trailer_offset = record_start + record_bytes - 4; trailer_crc = zlib.crc32(data[record_start:trailer_offset]) & 0xffffffff; data[trailer_offset:trailer_offset+4] = trailer_crc.to_bytes(4, 'little'); p.write_bytes(data)\"") == 0);

    var read_arena_buf: [byte: 8192] = [];
    var read_arena: Arena = Arena{ buffer: &read_arena_buf[0], size: 0, used: 0 };
    arena_init(&read_arena, &read_arena_buf[0], 8192 as usize);
    const snapshot: SegmentPackSnapshot = segment_pack_read("build/segment-pack-object-hash/packs/seg-000001.hgp", &read_arena) catch |err| {
        try expect(@error_id(err) == @error_id(error.SegmentPackInvalid));
        return;
    };
    _ = snapshot;
    return error.AssertionFailed;
}

fn test_segment_pack_index_reader_rejects_pack_hash_mismatch_with_valid_footer_crc() !void {
    try expect(system("rm -rf build/segment-pack-pack-hash && mkdir -p build/segment-pack-pack-hash/objects/loose build/segment-pack-pack-hash/packs") == 0);

    const store: LooseObjectStore = try loose_store_open("build/segment-pack-pack-hash/objects/loose");
    var payload: [byte: 4] = ['p' as byte, 'a' as byte, 'c' as byte, 'k' as byte];
    const id: ObjectId = try store.put(ObjectKind.Commit, payload[0: 4]);

    var arena_buf: [byte: 8192] = [];
    var arena: Arena = Arena{ buffer: &arena_buf[0], size: 0, used: 0 };
    arena_init(&arena, &arena_buf[0], 8192 as usize);
    const bytes: ObjectBytes = try store.get(ObjectId{ hash: id.hash }, &arena);

    var inputs: [SegmentPackWriteInput: 1] = [
        SegmentPackWriteInput{
            object_id: ObjectId{ hash: id.hash },
            kind: ObjectKind.Commit,
            flags: 0u16,
            logical_size: bytes.bytes.len as u64,
            object_bytes: ByteList{ ptr: bytes.bytes.ptr, len: bytes.bytes.len },
        },
    ];
    _ = try segment_pack_write(
        "build/segment-pack-pack-hash/packs/seg-000001.hgp",
        "build/segment-pack-pack-hash/packs/seg-000001.hgi",
        1u64,
        0i64,
        0u64,
        inputs[0: 1],
    );

    try expect(system("python3 -c \"from pathlib import Path; import zlib; p = Path('build/segment-pack-pack-hash/packs/seg-000001.hgi'); data = bytearray(p.read_bytes()); footer_start = len(data) - 72; data[footer_start] ^= 0x01; footer_crc = zlib.crc32(data[footer_start:len(data)-4]) & 0xffffffff; data[-4:] = footer_crc.to_bytes(4, 'little'); p.write_bytes(data)\"") == 0);

    var read_arena_buf: [byte: 8192] = [];
    var read_arena: Arena = Arena{ buffer: &read_arena_buf[0], size: 0, used: 0 };
    arena_init(&read_arena, &read_arena_buf[0], 8192 as usize);
    const snapshot: SegmentPackIndexSnapshot = segment_pack_index_read("build/segment-pack-pack-hash/packs/seg-000001.hgi", &read_arena) catch |err| {
        try expect(@error_id(err) == @error_id(error.SegmentPackInvalid));
        return;
    };
    _ = snapshot;
    return error.AssertionFailed;
}

fn test_loose_pack_compact() !void {
    try expect(system("rm -rf build/segment-pack-compact && mkdir -p build/segment-pack-compact/objects/loose build/segment-pack-compact/packs") == 0);

    const store: LooseObjectStore = try loose_store_open("build/segment-pack-compact/objects/loose");

    var payload_a: [byte: 6] = ['a' as byte, 'p' as byte, 'p' as byte, 'l' as byte, 'e' as byte, '1' as byte];
    var payload_b: [byte: 6] = ['a' as byte, 'p' as byte, 'p' as byte, 'l' as byte, 'e' as byte, '2' as byte];
    var payload_c: [byte: 6] = ['a' as byte, 'p' as byte, 'p' as byte, 'l' as byte, 'e' as byte, '3' as byte];
    const id_a: ObjectId = try store.put(ObjectKind.Commit, payload_a[0: 6]);
    const id_b: ObjectId = try store.put(ObjectKind.Commit, payload_b[0: 6]);
    const id_c: ObjectId = try store.put(ObjectKind.SmallBlob, payload_c[0: 6]);

    const result: CompactionResult = try loose_pack_compact(
        "build/segment-pack-compact/objects/loose",
        "build/segment-pack-compact/packs/seg-000001.hgp",
        "build/segment-pack-compact/packs/seg-000001.hgi",
        1u64,
        1000i64,
        0u64,
    );

    try expect(result.object_count == 3u64);
    try expect(result.pack_bytes > 0u64);
    try expect(result.index_bytes > 0u64);

    var read_arena_buf: [byte: 32768] = [];
    var read_arena: Arena = Arena{ buffer: &read_arena_buf[0], size: 0, used: 0 };
    arena_init(&read_arena, &read_arena_buf[0], 32768 as usize);

    const snapshot: SegmentPackSnapshot = try segment_pack_read("build/segment-pack-compact/packs/seg-000001.hgp", &read_arena);
    try expect(snapshot.header.object_count == 3u64);
    try expect(snapshot.header.segment_seq == 1u64);
    try expect(snapshot.header.created_at_ms == 1000i64);
    try expect(snapshot.records.len == 3 as usize);

    var found_ids: i32 = 0;
    var i: usize = 0 as usize;
    while i < snapshot.records.len {
        if object_id_compare(&snapshot.records.ptr[i].object_id, &id_a) == 0 {
            found_ids = found_ids | 1;
        }
        if object_id_compare(&snapshot.records.ptr[i].object_id, &id_b) == 0 {
            found_ids = found_ids | 2;
        }
        if object_id_compare(&snapshot.records.ptr[i].object_id, &id_c) == 0 {
            found_ids = found_ids | 4;
        }
        i = i + 1 as usize;
    }
    try expect(found_ids == 7);

    var lookup_arena_buf: [byte: 32768] = [];
    var lookup_arena: Arena = Arena{ buffer: &lookup_arena_buf[0], size: 0, used: 0 };
    arena_init(&lookup_arena, &lookup_arena_buf[0], 32768 as usize);

    const entry_a: SegmentPackIndexEntry = try segment_pack_index_lookup("build/segment-pack-compact/packs/seg-000001.hgi", ObjectId{ hash: id_a.hash }, &lookup_arena);
    try expect(object_id_compare(&entry_a.object_id, &id_a) == 0);
    try expect(entry_a.kind == ObjectKind.Commit);

    const entry_c: SegmentPackIndexEntry = try segment_pack_index_lookup("build/segment-pack-compact/packs/seg-000001.hgi", ObjectId{ hash: id_c.hash }, &lookup_arena);
    try expect(object_id_compare(&entry_c.object_id, &id_c) == 0);
    try expect(entry_c.kind == ObjectKind.SmallBlob);
}

fn test_loose_pack_compact_large_object() !void {
    try expect(system("rm -rf build/segment-pack-large && mkdir -p build/segment-pack-large/objects/loose build/segment-pack-large/packs") == 0);

    const store: LooseObjectStore = try loose_store_open("build/segment-pack-large/objects/loose");

    var payload: [byte: 70000] = [];
    const payload_len: usize = 70000 as usize;
    var i: usize = 0 as usize;
    while i < payload_len {
        payload[i] = ('a' as byte) + ((i % 26 as usize) as byte);
        i = i + 1 as usize;
    }
    const id: ObjectId = try store.put(ObjectKind.SmallBlob, payload[0: payload_len]);

    const result: CompactionResult = try loose_pack_compact(
        "build/segment-pack-large/objects/loose",
        "build/segment-pack-large/packs/seg-000001.hgp",
        "build/segment-pack-large/packs/seg-000001.hgi",
        1u64,
        2000i64,
        0u64,
    );

    try expect(result.object_count == 1u64);
    try expect(result.pack_bytes > 70000u64);

    var read_arena_buf: [byte: 131072] = [];
    var read_arena: Arena = Arena{ buffer: &read_arena_buf[0], size: 0, used: 0 };
    arena_init(&read_arena, &read_arena_buf[0], 131072 as usize);

    const snapshot: SegmentPackSnapshot = try segment_pack_read("build/segment-pack-large/packs/seg-000001.hgp", &read_arena);
    try expect(snapshot.records.len == 1 as usize);
    try expect(object_id_compare(&snapshot.records.ptr[0].object_id, &id) == 0);
    try expect(snapshot.records.ptr[0].kind == ObjectKind.SmallBlob);
    try expect(snapshot.records.ptr[0].object_bytes.len > 70000 as usize);
}

export fn main() i32 {
    test_suite_begin("HyperGit Segment Pack Tests");
    run_test("segment pack writer emits pack and sorted index", test_segment_pack_writer_roundtrip_layout);
    run_test("segment pack writer rejects duplicate object ids", test_segment_pack_writer_rejects_duplicate_object_ids);
    run_test("segment pack reader rejects corrupt record bytes", test_segment_pack_reader_rejects_corrupt_record_bytes);
    run_test("segment pack reader rejects corrupt footer bytes", test_segment_pack_reader_rejects_corrupt_footer_bytes);
    run_test("segment pack reader rejects object hash mismatch with valid crcs", test_segment_pack_reader_rejects_object_hash_mismatch_with_valid_crcs);
    run_test("segment pack index reader rejects pack hash mismatch with valid footer crc", test_segment_pack_index_reader_rejects_pack_hash_mismatch_with_valid_footer_crc);
    run_test("loose pack compact produces valid pack", test_loose_pack_compact);
    run_test("loose pack compact handles large objects", test_loose_pack_compact_large_object);
    return test_suite_end();
}
