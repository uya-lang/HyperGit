use libc.Stat;
use libc.errno;
use libc.getpid;
use libc.mkdir;
use libc.rename;
use libc.stat;
use libc.sys_gettid;
use libc.unlink;
use libc.EACCES;
use libc.EEXIST;
use libc.ENOENT;
use libc.EPERM;
use libc.O_CREAT;
use libc.O_EXCL;
