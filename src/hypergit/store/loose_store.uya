const STORE_PATH_MAX: usize = 4096;
const LOOSE_STORE_STAT_S_IFMT: u32 = 61440u32;
const LOOSE_STORE_STAT_S_IFDIR: u32 = 16384u32;
const LOOSE_STORE_FANOUT_HEX: &const byte = "0123456789abcdef";

error StorePathTooLong;
error StoreAlloc;
error StoreNotFound;
error StoreOpenFailed;
error StoreReadFailed;
error StoreWriteFailed;
error StoreCorruptObject;
error StoreHashMismatch;
error StorePermissionDenied;
error StorePublishFailed;
error StoreMkdirFailed;

struct StorePath {
    bytes: [byte: 4096] = [],
    len: usize = 0
}

fn loose_store_errno_is_permission() bool {
    return errno == EACCES || errno == EPERM;
}

fn store_path_empty() StorePath {
    return StorePath{ bytes: [], len: 0 };
}

fn store_path_clone(src: &StorePath) StorePath {
    var out: StorePath = store_path_empty();
    var i: usize = 0;
    while i < src.len {
        out.bytes[i] = src.bytes[i];
        i = i + 1;
    }
    out.bytes[src.len] = 0 as byte;
    out.len = src.len;
    return out;
}

fn store_path_cstr(path: &StorePath) &byte {
    return &path.bytes[0];
}

fn store_path_from_cstr(text: &byte) !StorePath {
    if text == null {
        return error.StorePathTooLong;
    }
    const len: usize = strlen(text as &const byte);
    if len >= STORE_PATH_MAX {
        return error.StorePathTooLong;
    }
    var out: StorePath = store_path_empty();
    var i: usize = 0;
    while i < len {
        out.bytes[i] = text[i];
        i = i + 1;
    }
    out.bytes[len] = 0 as byte;
    out.len = len;
    return out;
}

fn store_path_append_byte(path: &StorePath, value: byte) !void {
    if path.len + 1 >= STORE_PATH_MAX {
        return error.StorePathTooLong;
    }
    path.bytes[path.len] = value;
    path.len = path.len + 1;
    path.bytes[path.len] = 0 as byte;
}

fn store_path_append_bytes(path: &StorePath, src: &byte, count: usize) !void {
    if path.len + count >= STORE_PATH_MAX {
        return error.StorePathTooLong;
    }
    var i: usize = 0;
    while i < count {
        path.bytes[path.len + i] = src[i];
        i = i + 1;
    }
    path.len = path.len + count;
    path.bytes[path.len] = 0 as byte;
}

fn store_path_append_literal(path: &StorePath, literal: &const byte) !void {
    return store_path_append_bytes(path, literal as &byte, strlen(literal));
}

fn store_path_join_literal(base: &StorePath, literal: &const byte) !StorePath {
    var out: StorePath = store_path_empty();
    try store_path_append_bytes(&out, &base.bytes[0], base.len);
    if out.len > 0 {
        const last_index: usize = out.len - 1;
        if last_index < STORE_PATH_MAX && out.bytes[last_index] != '/' as byte {
            try store_path_append_byte(&out, '/' as byte);
        }
    }
    try store_path_append_literal(&out, literal);
    return out;
}

fn store_path_exists(path: &StorePath) bool {
    var st: Stat = Stat{};
    return stat(store_path_cstr(path) as &const byte, &st) == 0;
}

fn store_path_is_dir(path: &StorePath) bool {
    var st: Stat = Stat{};
    if stat(store_path_cstr(path) as &const byte, &st) != 0 {
        return false;
    }
    return (st.st_mode as u32 & LOOSE_STORE_STAT_S_IFMT) == LOOSE_STORE_STAT_S_IFDIR;
}

fn loose_store_ensure_dir(path: &StorePath) !void {
    if store_path_is_dir(path) {
        return;
    }
    if mkdir(store_path_cstr(path) as &const byte, S_IRWXU as i32) == 0 {
        return;
    }
    if store_path_is_dir(path) {
        return;
    }
    if loose_store_errno_is_permission() {
        return error.StorePermissionDenied;
    }
    return error.StoreMkdirFailed;
}

fn append_decimal_i32(path: &StorePath, value: i32) !void {
    var buf: [byte: 16] = [];
    var temp: i32 = value;
    if temp < 0 {
        temp = 0 - temp;
    }
    var count: usize = 0;
    if temp == 0 {
        buf[0] = '0' as byte;
        count = 1;
    } else {
        while temp > 0 {
            if count >= 16 as usize {
                return error.StorePathTooLong;
            }
            buf[count] = ('0' as byte) + (temp % 10) as byte;
            temp = temp / 10;
            count = count + 1;
        }
    }
    while count > 0 {
        count = count - 1;
        const idx: usize = count;
        if idx >= 16 as usize {
            return error.StorePathTooLong;
        }
        try store_path_append_byte(path, buf[idx]);
    }
}

fn hash_object_payload(kind: ObjectKind, payload: &[byte]) !ObjectId {
    const domain: &const byte = object_hash_domain(kind);
    const domain_len: usize = strlen(domain);
    const total_len: usize = domain_len + 1 + payload.len;
    const raw: &byte = malloc(total_len) as &byte;
    if raw == null {
        return error.StoreAlloc;
    }
    defer {
        free(raw as &void);
    }
    const combined: &[byte] = raw[0: total_len];

    var i: usize = 0;
    while i < domain_len {
        combined.ptr[i] = domain[i];
        i = i + 1;
    }
    combined.ptr[domain_len] = 0 as byte;
    i = 0;
    while i < payload.len {
        combined.ptr[domain_len + 1 + i] = payload.ptr[i];
        i = i + 1;
    }

    var hash: Hash32 = Hash32{ bytes: [] };
    hypergit_blake3_digest(combined, hash.bytes[0: HASH32_BYTES]);
    return object_id_from_hash(hash);
}

fn build_loose_object_paths(root: &StorePath, id: &ObjectId, dir_out: &StorePath, file_out: &StorePath) !void {
    var hex: [byte: 64] = [];
    _ = try object_id_encode_hex(id, hex[0: HASH32_HEX_BYTES]);

    var dir_path: StorePath = store_path_clone(root);
    if dir_path.len > 0 {
        const last_index: usize = dir_path.len - 1;
        if last_index < STORE_PATH_MAX && dir_path.bytes[last_index] != '/' as byte {
            try store_path_append_byte(&dir_path, '/' as byte);
        }
    }
    try store_path_append_bytes(&dir_path, &hex[0], 2 as usize);

    var file_path: StorePath = store_path_clone(&dir_path);
    try store_path_append_byte(&file_path, '/' as byte);
    try store_path_append_bytes(&file_path, &hex[2], HASH32_HEX_BYTES - 2 as usize);

    dir_out[0] = store_path_clone(&dir_path);
    file_out[0] = store_path_clone(&file_path);
}

fn build_loose_temp_path(file_path: &StorePath, temp_out: &StorePath) !void {
    var temp_path: StorePath = store_path_clone(file_path);
    try store_path_append_literal(&temp_path, ".tmp.");
    try append_decimal_i32(&temp_path, getpid());
    try store_path_append_byte(&temp_path, '.' as byte);
    const tid: i32 = sys_gettid() catch {
        return error.StorePathTooLong;
    };
    try append_decimal_i32(&temp_path, tid);

    temp_out[0] = store_path_clone(&temp_path);
}

fn build_loose_paths(root: &StorePath, id: &ObjectId, dir_out: &StorePath, file_out: &StorePath, temp_out: &StorePath) !void {
    try build_loose_object_paths(root, id, dir_out, file_out);
    try build_loose_temp_path(file_out, temp_out);
}

fn load_file_bytes(arena: &Arena, path: &StorePath) !ByteList {
    var st: Stat = Stat{};
    if stat(store_path_cstr(path) as &const byte, &st) != 0 {
        if errno == ENOENT {
            return error.StoreNotFound;
        }
        if loose_store_errno_is_permission() {
            return error.StorePermissionDenied;
        }
        return error.StoreOpenFailed;
    }

    const size: usize = st.st_size as usize;
    var want: usize = size;
    if want == 0 {
        want = 1 as usize;
    }
    const raw: &byte = arena_alloc(arena, want);
    if raw == null {
        return error.StoreAlloc;
    }
    const out: &[byte] = raw[0: size];
    const file: File = file_open(store_path_cstr(path) as &const byte, O_RDONLY as i32, 0u32) catch {
        return error.StoreOpenFailed;
    };
    defer {
        _ = file_close(&file) catch {};
    }

    var read_total: usize = 0;
    while read_total < size {
        const chunk: isize = file_read(&file, &raw[read_total], size - read_total);
        if chunk <= 0 {
            return error.StoreReadFailed;
        }
        read_total = read_total + chunk as usize;
    }
    return ByteList{ ptr: out.ptr, len: size };
}

fn verify_object_bytes(id: &ObjectId, data: ByteList) !void {
    var offset: usize = 0;
    const decoded: DecodedObject = codec_decode_object(data.ptr[0: data.len], &offset) catch {
        return error.StoreCorruptObject;
    };
    if offset != data.len {
        return error.StoreCorruptObject;
    }
    const kind: ObjectKind = object_kind_from_u16(decoded.envelope.kind) catch {
        return error.StoreCorruptObject;
    };
    const computed: ObjectId = try hash_object_payload(kind, decoded.payload.ptr[0: decoded.payload.len]);
    if object_id_compare(&computed, id) != 0 {
        return error.StoreHashMismatch;
    }
}

fn loose_store_put_with_id(self: &LooseObjectStore, id: &ObjectId, kind: ObjectKind, payload: &[byte], check_existing: bool) !ObjectId {
    if check_existing && (try self.has(id[0])) {
        return id[0];
    }

    var dir_path: StorePath = store_path_empty();
    var file_path: StorePath = store_path_empty();
    var temp_path: StorePath = store_path_empty();
    try build_loose_paths(&self.root, id, &dir_path, &file_path, &temp_path);
    if !self.fanout_prepared {
        try loose_store_ensure_dir(&dir_path);
    }

    const total_len: usize = CODEC_ENVELOPE_BYTES + payload.len;
    const encoded_raw: &byte = malloc(total_len) as &byte;
    if encoded_raw == null {
        return error.StoreAlloc;
    }
    defer {
        free(encoded_raw as &void);
    }
    const encoded: &[byte] = encoded_raw[0: total_len];
    var offset: usize = 0;
    try codec_encode_object(encoded, &offset, object_kind_to_u16(kind), 0 as u16, payload);

    const file: File = file_open(store_path_cstr(&temp_path) as &const byte, (O_WRONLY | O_CREAT | O_EXCL) as i32, S_IRWXU as u32) catch {
        if loose_store_errno_is_permission() {
            return error.StorePermissionDenied;
        }
        return error.StoreWriteFailed;
    };
    defer {
        _ = file_close(&file) catch {};
    }

    var written_total: usize = 0;
    while written_total < total_len {
        const chunk_written: usize = try file_write(
            &file,
            @ptr_from_usize(@usize_from_ptr(encoded.ptr as &void) + written_total) as &const byte,
            total_len - written_total,
        );
        if chunk_written == 0 {
            _ = unlink(store_path_cstr(&temp_path) as &const byte);
            return error.StoreWriteFailed;
        }
        written_total = written_total + chunk_written;
    }

    _ = file_close(&file) catch {
        _ = unlink(store_path_cstr(&temp_path) as &const byte);
        return error.StoreWriteFailed;
    };

    if rename(store_path_cstr(&temp_path) as &const byte, store_path_cstr(&file_path) as &const byte) != 0 {
        if try self.has(id[0]) {
            _ = unlink(store_path_cstr(&temp_path) as &const byte);
            return id[0];
        }
        _ = unlink(store_path_cstr(&temp_path) as &const byte);
        return error.StorePublishFailed;
    }

    return id[0];
}

export struct LooseObjectStore : ObjectStore {
    root: StorePath,
    fanout_prepared: bool,
    packs: PackSet,

    fn has(self: &Self, id: ObjectId) !bool {
        var dir_path: StorePath = store_path_empty();
        var file_path: StorePath = store_path_empty();
        try build_loose_object_paths(&self.root, &id, &dir_path, &file_path);
        if store_path_exists(&file_path) {
            return true;
        }
        return try pack_set_has(&self.packs, ObjectId{ hash: id.hash });
    },

    fn get(self: &Self, id: ObjectId, arena: &Arena) !ObjectBytes {
        var dir_path: StorePath = store_path_empty();
        var file_path: StorePath = store_path_empty();
        try build_loose_object_paths(&self.root, &id, &dir_path, &file_path);
        if store_path_exists(&file_path) {
            const data: ByteList = try load_file_bytes(arena, &file_path);
            try verify_object_bytes(&id, data);
            return ObjectBytes{ bytes: data };
        }
        var found: bool = false;
        const packed: ByteList = try pack_set_get(&self.packs, ObjectId{ hash: id.hash }, arena, &found);
        if found {
            return ObjectBytes{ bytes: packed };
        }
        return error.StoreNotFound;
    },

    fn put(self: &Self, kind: ObjectKind, payload: &[byte]) !ObjectId {
        const id: ObjectId = try hash_object_payload(kind, payload);
        return try loose_store_put_with_id(self, &id, kind, payload, true);
    },

    fn open_reader(self: &Self, id: ObjectId) !ObjectReader {
        var dir_path: StorePath = store_path_empty();
        var file_path: StorePath = store_path_empty();
        try build_loose_object_paths(&self.root, &id, &dir_path, &file_path);
        const file: File = file_open(store_path_cstr(&file_path) as &const byte, O_RDONLY as i32, 0u32) catch {
            return error.StoreOpenFailed;
        };
        return ObjectReader{ file: file };
    },
}

export fn loose_store_open(root_path: &byte) !LooseObjectStore {
    return LooseObjectStore{
        root: try store_path_from_cstr(root_path),
        fanout_prepared: false,
        packs: pack_set_empty(),
    };
}

// Open a loose store that also serves objects from segment packs in packs_dir.
// Reads check the loose object first, then fall back to the packs (index lookup
// + single-record read). Writes/put still go to the loose layer. Use this for
// read paths that must see objects `hgx add` placed into packs.
export fn loose_store_open_packed(root_path: &byte, packs_dir: &const byte) !LooseObjectStore {
    return LooseObjectStore{
        root: try store_path_from_cstr(root_path),
        fanout_prepared: false,
        packs: try pack_set_open(packs_dir),
    };
}

// Resolve an object's logical size from the pack index without reading bytes.
// Returns false when the id is not packed (caller should decode the loose object).
export fn loose_store_pack_logical_size(store: &LooseObjectStore, id: &ObjectId, out: &u64) !bool {
    return try pack_set_logical_size(&store.packs, ObjectId{ hash: id[0].hash }, out);
}

export fn loose_store_prepare_fanout_dirs(store: &LooseObjectStore) !void {
    var high: usize = 0 as usize;
    while high < 16 as usize {
        var low: usize = 0 as usize;
        while low < 16 as usize {
            var dir_path: StorePath = store_path_clone(&store.root);
            if dir_path.len > 0 as usize {
                const last_index: usize = dir_path.len - 1 as usize;
                if last_index < STORE_PATH_MAX && dir_path.bytes[last_index] != '/' as byte {
                    try store_path_append_byte(&dir_path, '/' as byte);
                }
            }
            try store_path_append_byte(&dir_path, LOOSE_STORE_FANOUT_HEX[high]);
            try store_path_append_byte(&dir_path, LOOSE_STORE_FANOUT_HEX[low]);
            try loose_store_ensure_dir(&dir_path);
            low = low + 1 as usize;
        }
        high = high + 1 as usize;
    }
    store.fanout_prepared = true;
}

export fn loose_store_put_known_id(store: &LooseObjectStore, id: &ObjectId, kind: ObjectKind, payload: &[byte]) !ObjectId {
    return try loose_store_put_with_id(store, id, kind, payload, true);
}

export fn loose_store_put_known_id_fresh(store: &LooseObjectStore, id: &ObjectId, kind: ObjectKind, payload: &[byte]) !ObjectId {
    return try loose_store_put_with_id(store, id, kind, payload, false);
}

export fn loose_store_object_path(store: &LooseObjectStore, id: &ObjectId, out: &[byte]) !usize {
    var dir_path: StorePath = store_path_empty();
    var file_path: StorePath = store_path_empty();
    try build_loose_object_paths(&store.root, id, &dir_path, &file_path);
    if file_path.len + 1 > out.len {
        return error.StorePathTooLong;
    }
    var i: usize = 0;
    while i <= file_path.len {
        out.ptr[i] = file_path.bytes[i];
        i = i + 1;
    }
    return file_path.len;
}
