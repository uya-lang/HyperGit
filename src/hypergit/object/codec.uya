}

export fn decode_published_view_object(input: &[byte], offset: &usize) !PublishedView {
    const decoded: DecodedObject = try codec_decode_object(input, offset);
    try decode_expected_kind(decoded, ObjectKind.PublishedView);
    var payload_offset: usize = 0;
    return try decode_published_view_payload(decoded.payload.ptr[0: decoded.payload.len], &payload_offset);
}

export fn decode_object_kind(input: &[byte], offset: &usize) !ObjectKind {
    const decoded: DecodedObject = try codec_decode_object(input, offset);
    return object_kind_from_u16(decoded.envelope.kind) catch |err| {
        _ = err;
        return error.CodecNonCanonical;
    };
}
