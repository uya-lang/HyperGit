export fn published_view_payload_to_canonical(arena: &Arena, payload: &PublishedView) !ByteList {
    const len: usize = published_view_payload_encoded_len(payload);
    const out: &[byte] = try arena_bytes(arena, len);
    var offset: usize = 0;
    try encode_published_view_payload(out, &offset, payload);
    if offset != len {
        return error.CodecNonCanonical;
    }
    return ByteList{ ptr: out.ptr, len: len };
}

fn object_payload_slice(payload: ByteList) &[byte] {
    return payload.ptr[0: payload.len];
}

fn decode_expected_kind(decoded: DecodedObject, expected: ObjectKind) !void {
    const actual: ObjectKind = object_kind_from_u16(decoded.envelope.kind) catch |err| {
        _ = err;
        return error.CodecNonCanonical;
    };
    if actual != expected {
        return error.ObjectUnexpectedKind;
    }
}

export fn encode_commit_object(arena: &Arena, output: &[byte], offset: &usize, payload: &CommitPayload) !void {
    const encoded: ByteList = try commit_payload_to_canonical(arena, payload);
    try codec_encode_object(output, offset, object_kind_to_u16(ObjectKind.Commit), 0 as u16, object_payload_slice(encoded));
}

export fn decode_commit_object(arena: &Arena, input: &[byte], offset: &usize) !CommitPayload {
    const decoded: DecodedObject = try codec_decode_object(input, offset);
    try decode_expected_kind(decoded, ObjectKind.Commit);
    var payload_offset: usize = 0;
    return try decode_commit_payload(arena, decoded.payload.ptr[0: decoded.payload.len], &payload_offset);
}

export fn encode_manifest_node_object(arena: &Arena, output: &[byte], offset: &usize, payload: &ManifestNodePayload) !void {
    const encoded: ByteList = try manifest_node_payload_to_canonical(arena, payload);
    try codec_encode_object(output, offset, object_kind_to_u16(ObjectKind.ManifestNode), 0 as u16, object_payload_slice(encoded));
}

export fn decode_manifest_node_object(arena: &Arena, input: &[byte], offset: &usize) !ManifestNodePayload {
    const decoded: DecodedObject = try codec_decode_object(input, offset);
    try decode_expected_kind(decoded, ObjectKind.ManifestNode);
    var payload_offset: usize = 0;
    return try decode_manifest_node_payload(arena, decoded.payload.ptr[0: decoded.payload.len], &payload_offset);
}

export fn encode_small_blob_object(arena: &Arena, output: &[byte], offset: &usize, payload: &SmallBlobPayload) !void {
    const encoded: ByteList = try small_blob_payload_to_canonical(arena, payload);
    try codec_encode_object(output, offset, object_kind_to_u16(ObjectKind.SmallBlob), 0 as u16, object_payload_slice(encoded));
}

export fn decode_small_blob_object(input: &[byte], offset: &usize) !SmallBlobPayload {
