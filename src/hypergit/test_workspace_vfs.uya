fn make_hash(seed: byte) Hash32 {
    var hash: Hash32 = Hash32{ bytes: [] };
    var i: usize = 0 as usize;
    while i < 32 as usize {
        hash.bytes[i] = seed + i as byte;
        i = i + 1 as usize;
    }
    return hash;
}

fn test_vfs_plan_placeholders_tracks_virtual_materialized_and_dirty() !void {
    var arena_buf: [byte: 16384] = [];
    var arena: Arena = Arena{ buffer: &arena_buf[0], size: 0, used: 0 };
    arena_init(&arena, &arena_buf[0], 16384 as usize);

    var alpha_path: [byte: 9] = ['a' as byte, 'l' as byte, 'p' as byte, 'h' as byte, 'a' as byte, '.' as byte, 't' as byte, 'x' as byte, 't' as byte];
    var beta_path: [byte: 8] = ['b' as byte, 'e' as byte, 't' as byte, 'a' as byte, '.' as byte, 't' as byte, 'x' as byte, 't' as byte];
    var gamma_path: [byte: 9] = ['g' as byte, 'a' as byte, 'm' as byte, 'm' as byte, 'a' as byte, '.' as byte, 't' as byte, 'x' as byte, 't' as byte];

    var full_inputs: [ManifestLeafInputEntry: 3] = [
        ManifestLeafInputEntry{
            path: ByteList{ ptr: alpha_path[0: 9].ptr, len: 9 as usize },
            kind: EntryKind.File,
            mode: 33188u32,
            object_id: object_id_from_hash(make_hash(1 as byte)),
            logical_size: 5u64,
            content_type: ContentType.Unknown,
            policy_id: policy_id_from_object(object_id_from_hash(make_hash(2 as byte))),
        },
        ManifestLeafInputEntry{
            path: ByteList{ ptr: beta_path[0: 8].ptr, len: 8 as usize },
            kind: EntryKind.File,
            mode: 33188u32,
            object_id: object_id_from_hash(make_hash(3 as byte)),
            logical_size: 4u64,
            content_type: ContentType.Unknown,
            policy_id: policy_id_from_object(object_id_from_hash(make_hash(4 as byte))),
        },
        ManifestLeafInputEntry{
            path: ByteList{ ptr: gamma_path[0: 9].ptr, len: 9 as usize },
            kind: EntryKind.File,
            mode: 33188u32,
            object_id: object_id_from_hash(make_hash(5 as byte)),
            logical_size: 5u64,
            content_type: ContentType.Unknown,
            policy_id: policy_id_from_object(object_id_from_hash(make_hash(6 as byte))),
        },
    ];
    var materialized_inputs: [ManifestLeafInputEntry: 2] = [full_inputs[0], full_inputs[1]];
    var local_changes: [LocalChange: 2] = [
        LocalChange{
            path: ByteList{ ptr: alpha_path[0: 9].ptr, len: 9 as usize },
            base_object: full_inputs[0].object_id,
            working_hash: make_hash(7 as byte),
            status: ChangeStatus.Materialized,
            last_seen_inode: 0u64,
            last_seen_mtime_ns: 0i64,
            last_seen_logical_size: 5u64,
            last_seen_file_mode: full_inputs[0].mode,
            watcher_seq: 0u64,
            reconcile_epoch: 0u64,
        },
        LocalChange{
            path: ByteList{ ptr: beta_path[0: 8].ptr, len: 8 as usize },
            base_object: full_inputs[1].object_id,
            working_hash: make_hash(8 as byte),
            status: ChangeStatus.Modified,
            last_seen_inode: 0u64,
            last_seen_mtime_ns: 0i64,
            last_seen_logical_size: 4u64,
            last_seen_file_mode: full_inputs[1].mode,
            watcher_seq: 0u64,
            reconcile_epoch: 0u64,
        },
    ];

    const full_list: ManifestLeafInputList = manifest_leaf_input_list_from_slice(full_inputs[0: 3]);
    const materialized_list: ManifestLeafInputList = manifest_leaf_input_list_from_slice(materialized_inputs[0: 2]);
    const change_list: LocalChangeList = local_change_list_from_slice(local_changes[0: 2]);
    const placeholders: VfsPlaceholderEntryList = try vfs_plan_placeholders(
        &arena,
        &full_list,
        &materialized_list,
        &change_list,
    );
    try expect(placeholders.len == 3 as usize);
    try expect(placeholders.ptr[0].state == VfsPlaceholderState.Materialized);
    try expect(placeholders.ptr[1].state == VfsPlaceholderState.DirtyMaterialized);
    try expect(placeholders.ptr[2].state == VfsPlaceholderState.VirtualOnly);
}

fn test_vfs_plan_materialization_requests_tracks_materialize_and_dehydrate() !void {
    var arena_buf: [byte: 16384] = [];
    var arena: Arena = Arena{ buffer: &arena_buf[0], size: 0, used: 0 };
    arena_init(&arena, &arena_buf[0], 16384 as usize);

    var alpha_path: [byte: 9] = ['a' as byte, 'l' as byte, 'p' as byte, 'h' as byte, 'a' as byte, '.' as byte, 't' as byte, 'x' as byte, 't' as byte];
    var beta_path: [byte: 8] = ['b' as byte, 'e' as byte, 't' as byte, 'a' as byte, '.' as byte, 't' as byte, 'x' as byte, 't' as byte];
    var gamma_path: [byte: 9] = ['g' as byte, 'a' as byte, 'm' as byte, 'm' as byte, 'a' as byte, '.' as byte, 't' as byte, 'x' as byte, 't' as byte];

    var current_materialized: [ManifestLeafInputEntry: 2] = [
        ManifestLeafInputEntry{
            path: ByteList{ ptr: alpha_path[0: 9].ptr, len: 9 as usize },
            kind: EntryKind.File,
            mode: 33188u32,
            object_id: object_id_from_hash(make_hash(10 as byte)),
            logical_size: 5u64,
            content_type: ContentType.Unknown,
            policy_id: policy_id_from_object(object_id_from_hash(make_hash(11 as byte))),
        },
        ManifestLeafInputEntry{
            path: ByteList{ ptr: beta_path[0: 8].ptr, len: 8 as usize },
            kind: EntryKind.File,
            mode: 33188u32,
            object_id: object_id_from_hash(make_hash(12 as byte)),
            logical_size: 4u64,
            content_type: ContentType.Unknown,
            policy_id: policy_id_from_object(object_id_from_hash(make_hash(13 as byte))),
        },
    ];
    var target_materialized: [ManifestLeafInputEntry: 2] = [current_materialized[0], ManifestLeafInputEntry{
        path: ByteList{ ptr: gamma_path[0: 9].ptr, len: 9 as usize },
        kind: EntryKind.File,
        mode: 33188u32,
        object_id: object_id_from_hash(make_hash(14 as byte)),
        logical_size: 5u64,
        content_type: ContentType.Unknown,
        policy_id: policy_id_from_object(object_id_from_hash(make_hash(15 as byte))),
    }];

    const current_list: ManifestLeafInputList = manifest_leaf_input_list_from_slice(current_materialized[0: 2]);
    const target_list: ManifestLeafInputList = manifest_leaf_input_list_from_slice(target_materialized[0: 2]);
    const requests: VfsMaterializationRequestList = try vfs_plan_materialization_requests(
        &arena,
        &current_list,
        &target_list,
    );
    try expect(requests.len == 2 as usize);
    try expect(requests.ptr[0].kind == VfsMaterializationRequestKind.Dehydrate);
    try expect(requests.ptr[0].path.ptr[0] == 'b' as byte);
    try expect(requests.ptr[1].kind == VfsMaterializationRequestKind.Materialize);
    try expect(requests.ptr[1].path.ptr[0] == 'g' as byte);
}

fn test_vfs_workspace_plan_builds_visible_views_and_requests() !void {
    var arena_buf: [byte: 16384] = [];
    var arena: Arena = Arena{ buffer: &arena_buf[0], size: 0, used: 0 };
    arena_init(&arena, &arena_buf[0], 16384 as usize);

    var alpha_path: [byte: 9] = ['a' as byte, 'l' as byte, 'p' as byte, 'h' as byte, 'a' as byte, '.' as byte, 't' as byte, 'x' as byte, 't' as byte];
    var beta_path: [byte: 8] = ['b' as byte, 'e' as byte, 't' as byte, 'a' as byte, '.' as byte, 't' as byte, 'x' as byte, 't' as byte];
    var gamma_path: [byte: 9] = ['g' as byte, 'a' as byte, 'm' as byte, 'm' as byte, 'a' as byte, '.' as byte, 't' as byte, 'x' as byte, 't' as byte];

    var full_inputs: [ManifestLeafInputEntry: 3] = [
        ManifestLeafInputEntry{
            path: ByteList{ ptr: alpha_path[0: 9].ptr, len: 9 as usize },
            kind: EntryKind.File,
            mode: 33188u32,
            object_id: object_id_from_hash(make_hash(20 as byte)),
            logical_size: 5u64,
            content_type: ContentType.Unknown,
            policy_id: policy_id_from_object(object_id_from_hash(make_hash(21 as byte))),
        },
        ManifestLeafInputEntry{
            path: ByteList{ ptr: beta_path[0: 8].ptr, len: 8 as usize },
            kind: EntryKind.File,
            mode: 33188u32,
            object_id: object_id_from_hash(make_hash(22 as byte)),
            logical_size: 4u64,
            content_type: ContentType.Unknown,
            policy_id: policy_id_from_object(object_id_from_hash(make_hash(23 as byte))),
        },
        ManifestLeafInputEntry{
            path: ByteList{ ptr: gamma_path[0: 9].ptr, len: 9 as usize },
            kind: EntryKind.File,
            mode: 33188u32,
            object_id: object_id_from_hash(make_hash(24 as byte)),
            logical_size: 5u64,
            content_type: ContentType.Unknown,
            policy_id: policy_id_from_object(object_id_from_hash(make_hash(25 as byte))),
        },
    ];
    var current_changes: [LocalChange: 2] = [
        LocalChange{
            path: ByteList{ ptr: alpha_path[0: 9].ptr, len: 9 as usize },
            base_object: full_inputs[0].object_id,
            working_hash: make_hash(26 as byte),
            status: ChangeStatus.Materialized,
            last_seen_inode: 1u64,
            last_seen_mtime_ns: 1i64,
            last_seen_logical_size: 5u64,
            last_seen_file_mode: full_inputs[0].mode,
            watcher_seq: 1u64,
            reconcile_epoch: 1u64,
        },
        LocalChange{
            path: ByteList{ ptr: beta_path[0: 8].ptr, len: 8 as usize },
            base_object: full_inputs[1].object_id,
            working_hash: make_hash(27 as byte),
            status: ChangeStatus.Materialized,
            last_seen_inode: 2u64,
            last_seen_mtime_ns: 2i64,
            last_seen_logical_size: 4u64,
            last_seen_file_mode: full_inputs[1].mode,
            watcher_seq: 2u64,
            reconcile_epoch: 2u64,
        },
    ];
    var target_changes: [LocalChange: 2] = [
        current_changes[0],
        LocalChange{
            path: ByteList{ ptr: beta_path[0: 8].ptr, len: 8 as usize },
            base_object: full_inputs[1].object_id,
            working_hash: make_hash(28 as byte),
            status: ChangeStatus.Virtual,
            last_seen_inode: 0u64,
            last_seen_mtime_ns: 0i64,
            last_seen_logical_size: 0u64,
            last_seen_file_mode: full_inputs[1].mode,
            watcher_seq: 3u64,
            reconcile_epoch: 3u64,
        },
    ];

    const full_list: ManifestLeafInputList = manifest_leaf_input_list_from_slice(full_inputs[0: 3]);
    const current_change_list: LocalChangeList = local_change_list_from_slice(current_changes[0: 2]);
    const target_change_list: LocalChangeList = local_change_list_from_slice(target_changes[0: 2]);
    const profile: SparseProfile = try sparse_profile_default(&arena);
    const plan: VfsWorkspacePlan = try vfs_workspace_plan_build(
        &arena,
        VfsProviderKind.UserSpace,
        &full_list,
        &profile,
        &current_change_list,
        &target_change_list,
    );

    try expect(plan.provider_kind == VfsProviderKind.UserSpace);
    try expect(plan.current_materialized.len == 3 as usize);
    try expect(plan.target_materialized.len == 2 as usize);
    try expect(plan.placeholder_entries.len == 3 as usize);
    try expect(plan.materialization_requests.len == 1 as usize);
    try expect(plan.materialization_requests.ptr[0].kind == VfsMaterializationRequestKind.Dehydrate);
    try expect(plan.materialization_requests.ptr[0].path.ptr[0] == 'b' as byte);
}

fn test_vfs_platform_boundary_degrades_non_linux_platforms_to_user_space() !void {
    const linux_boundary: VfsPlatformBoundary = vfs_platform_boundary_for(VfsPlatformKind.Linux);
    try expect(linux_boundary.provider_kind == VfsProviderKind.FuseLinux);
    try expect(linux_boundary.boundary_kind == VfsBoundaryKind.KernelMounted);
    try expect(linux_boundary.degrade_kind == VfsDegradeKind.None);
    try expect(linux_boundary.mount_supported);

    const mac_boundary: VfsPlatformBoundary = vfs_platform_boundary_for(VfsPlatformKind.MacOS);
    try expect(mac_boundary.provider_kind == VfsProviderKind.UserSpace);
    try expect(mac_boundary.boundary_kind == VfsBoundaryKind.UserSpaceProjected);
    try expect(mac_boundary.degrade_kind == VfsDegradeKind.UserSpaceProjection);
    try expect(!mac_boundary.mount_supported);

    const windows_boundary: VfsPlatformBoundary = vfs_platform_boundary_for(VfsPlatformKind.Windows);
    try expect(windows_boundary.provider_kind == VfsProviderKind.UserSpace);
    try expect(windows_boundary.boundary_kind == VfsBoundaryKind.UserSpaceProjected);
    try expect(windows_boundary.degrade_kind == VfsDegradeKind.UserSpaceProjection);
    try expect(!windows_boundary.mount_supported);
}

export fn main() i32 {
    test_suite_begin("HyperGit Workspace VFS Tests");
    run_test("vfs plan placeholders tracks virtual materialized and dirty", test_vfs_plan_placeholders_tracks_virtual_materialized_and_dirty);
    run_test("vfs plan materialization requests tracks materialize and dehydrate", test_vfs_plan_materialization_requests_tracks_materialize_and_dehydrate);
    run_test("vfs workspace plan builds visible views and requests", test_vfs_workspace_plan_builds_visible_views_and_requests);
    run_test("vfs platform boundary degrades non linux platforms to user space", test_vfs_platform_boundary_degrades_non_linux_platforms_to_user_space);
    return test_suite_end();
}
