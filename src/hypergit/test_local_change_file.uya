use std.runtime.entry;
use std.testing.expect;
use std.testing.run_test;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.mem.arena.Arena;
use std.mem.arena.arena_init;

use libc.free;
use libc.malloc;
use libc.system;
use core.ids.Hash32;
use core.ids.hash32_compare;
use core.ids.object_id_from_hash;
use object.types.ByteList;
use workspace.local_change_file.local_change_file_read;
use workspace.local_change_file.local_change_file_replace_existing;
use workspace.local_change_file.local_change_file_write;
use workspace.state.ChangeStatus;
use workspace.state.LocalChange;
use workspace.state.LocalChangeList;
use workspace.state.local_change_list_from_slice;

fn make_hash(seed: byte) Hash32 {
    var hash: Hash32 = Hash32{ bytes: [] };
    var i: usize = 0;
    while i < 32 as usize {
        hash.bytes[i] = seed + i as byte;
        i = i + 1 as usize;
    }
    return hash;
}

fn test_local_change_file_roundtrip() !void {
    try expect(system("rm -rf build/local-change-test && mkdir -p build/local-change-test") == 0);

    var path_a: [byte: 5] = ['a' as byte, '.' as byte, 't' as byte, 'x' as byte, 't' as byte];
    var path_b: [byte: 5] = ['b' as byte, '.' as byte, 't' as byte, 'x' as byte, 't' as byte];
    var path_c: [byte: 10] = ['v' as byte, 'i' as byte, 'r' as byte, 't' as byte, 'u' as byte, 'a' as byte, 'l' as byte, '.' as byte, 'm' as byte, 'd' as byte];
    var changes: [LocalChange: 3] = [
        LocalChange{
            path: ByteList{ ptr: path_a[0: 5].ptr, len: 5 as usize },
            base_object: object_id_from_hash(make_hash(1 as byte)),
            working_hash: make_hash(2 as byte),
            status: ChangeStatus.Materialized,
            last_seen_inode: 11u64,
            last_seen_mtime_ns: 22i64,
            last_seen_logical_size: 5u64,
            last_seen_file_mode: 33188u32,
            watcher_seq: 3u64,
            reconcile_epoch: 4u64,
        },
        LocalChange{
            path: ByteList{ ptr: path_b[0: 5].ptr, len: 5 as usize },
            base_object: object_id_from_hash(make_hash(5 as byte)),
            working_hash: make_hash(6 as byte),
            status: ChangeStatus.Modified,
            last_seen_inode: 33u64,
            last_seen_mtime_ns: 44i64,
            last_seen_logical_size: 5u64,
            last_seen_file_mode: 33188u32,
            watcher_seq: 7u64,
            reconcile_epoch: 8u64,
        },
        LocalChange{
            path: ByteList{ ptr: path_c[0: 10].ptr, len: 10 as usize },
            base_object: object_id_from_hash(make_hash(9 as byte)),
            working_hash: make_hash(10 as byte),
            status: ChangeStatus.Virtual,
            last_seen_inode: 0u64,
            last_seen_mtime_ns: 0i64,
            last_seen_logical_size: 0u64,
            last_seen_file_mode: 0u32,
            watcher_seq: 0u64,
            reconcile_epoch: 0u64,
        },
    ];

    const list: LocalChangeList = local_change_list_from_slice(changes[0: 3]);
    try local_change_file_write("build/local-change-test/local-change.hgi", &list);

    var arena_buf: [byte: 16384] = [];
    var arena: Arena = Arena{ buffer: &arena_buf[0], size: 0, used: 0 };
    arena_init(&arena, &arena_buf[0], 16384 as usize);
    const loaded: LocalChangeList = try local_change_file_read(&arena, "build/local-change-test/local-change.hgi");

    try expect(loaded.len == 3 as usize);
    try expect(loaded.ptr[0].status == ChangeStatus.Materialized);
    try expect(loaded.ptr[1].status == ChangeStatus.Modified);
    try expect(loaded.ptr[2].status == ChangeStatus.Virtual);
    try expect(loaded.ptr[0].last_seen_inode == 11u64);
    try expect(loaded.ptr[0].last_seen_logical_size == 5u64);
    try expect(loaded.ptr[0].last_seen_file_mode == 33188u32);
    try expect(loaded.ptr[1].reconcile_epoch == 8u64);
}

fn test_local_change_file_roundtrip_above_legacy_size_limit() !void {
    const ENTRY_COUNT: usize = 40000 as usize;

    try expect(system("rm -rf build/local-change-large && mkdir -p build/local-change-large") == 0);

    const raw_changes: &LocalChange = malloc(@size_of(LocalChange) as usize * ENTRY_COUNT) as &LocalChange;
    try expect(raw_changes != null);
    defer {
        free(raw_changes as &void);
    }

    var path_buf: [byte: 10] = ['m' as byte, 'a' as byte, 'n' as byte, 'y' as byte, '.' as byte, 't' as byte, 'x' as byte, 't' as byte, '0' as byte, '1' as byte];
    var i: usize = 0 as usize;
    while i < ENTRY_COUNT {
        raw_changes[i] = LocalChange{
            path: ByteList{ ptr: path_buf[0: 10].ptr, len: 10 as usize },
            base_object: object_id_from_hash(make_hash((i % 200 as usize) as byte)),
            working_hash: make_hash(((i + 1 as usize) % 200 as usize) as byte),
            status: ChangeStatus.Modified,
            last_seen_inode: i as u64,
            last_seen_mtime_ns: i as i64,
            last_seen_logical_size: 10u64,
            last_seen_file_mode: 33188u32,
            watcher_seq: i as u64,
            reconcile_epoch: (i / 2 as usize) as u64,
        };
        i = i + 1 as usize;
    }

    const list: LocalChangeList = local_change_list_from_slice(raw_changes[0: ENTRY_COUNT]);
    try local_change_file_write("build/local-change-large/local-change.hgi", &list);

    const arena_bytes: usize = 16777216 as usize;
    const arena_buf: &byte = malloc(arena_bytes) as &byte;
    try expect(arena_buf != null);
    defer {
        free(arena_buf as &void);
    }
    var arena: Arena = Arena{ buffer: arena_buf, size: 0, used: 0 };
    arena_init(&arena, arena_buf, arena_bytes);
    const loaded: LocalChangeList = try local_change_file_read(&arena, "build/local-change-large/local-change.hgi");

    try expect(loaded.len == ENTRY_COUNT);
    try expect(loaded.ptr[0].status == ChangeStatus.Modified);
    try expect(loaded.ptr[ENTRY_COUNT - 1 as usize].last_seen_inode == (ENTRY_COUNT - 1 as usize) as u64);
    try expect(loaded.ptr[ENTRY_COUNT - 1 as usize].path.len == 10 as usize);
}

fn test_local_change_file_replace_existing_preserves_counters() !void {
    try expect(system("rm -rf build/local-change-replace && mkdir -p build/local-change-replace") == 0);

    var path_a: [byte: 5] = ['a' as byte, '.' as byte, 't' as byte, 'x' as byte, 't' as byte];
    var path_b: [byte: 5] = ['b' as byte, '.' as byte, 't' as byte, 'x' as byte, 't' as byte];
    var changes: [LocalChange: 2] = [
        LocalChange{
            path: ByteList{ ptr: path_a[0: 5].ptr, len: 5 as usize },
            base_object: object_id_from_hash(make_hash(1 as byte)),
            working_hash: make_hash(2 as byte),
            status: ChangeStatus.Materialized,
            last_seen_inode: 11u64,
            last_seen_mtime_ns: 22i64,
            last_seen_logical_size: 5u64,
            last_seen_file_mode: 33188u32,
            watcher_seq: 3u64,
            reconcile_epoch: 4u64,
        },
        LocalChange{
            path: ByteList{ ptr: path_b[0: 5].ptr, len: 5 as usize },
            base_object: object_id_from_hash(make_hash(5 as byte)),
            working_hash: make_hash(6 as byte),
            status: ChangeStatus.Materialized,
            last_seen_inode: 33u64,
            last_seen_mtime_ns: 44i64,
            last_seen_logical_size: 5u64,
            last_seen_file_mode: 33188u32,
            watcher_seq: 7u64,
            reconcile_epoch: 8u64,
        },
    ];

    const list: LocalChangeList = local_change_list_from_slice(changes[0: 2]);
    try local_change_file_write("build/local-change-replace/local-change.hgi", &list);

    var update: LocalChange = LocalChange{
        path: ByteList{ ptr: path_b[0: 5].ptr, len: 5 as usize },
        base_object: object_id_from_hash(make_hash(5 as byte)),
        working_hash: make_hash(99 as byte),
        status: ChangeStatus.Modified,
        last_seen_inode: 330u64,
        last_seen_mtime_ns: 440i64,
        last_seen_logical_size: 55u64,
        last_seen_file_mode: 33261u32,
        watcher_seq: 0u64,
        reconcile_epoch: 0u64,
    };

    var replace_buf: [byte: 16384] = [];
    var replace_arena: Arena = Arena{ buffer: &replace_buf[0], size: 0, used: 0 };
    arena_init(&replace_arena, &replace_buf[0], 16384 as usize);
    try expect(try local_change_file_replace_existing(&replace_arena, "build/local-change-replace/local-change.hgi", &update));

    var arena_buf: [byte: 16384] = [];
    var arena: Arena = Arena{ buffer: &arena_buf[0], size: 0, used: 0 };
    arena_init(&arena, &arena_buf[0], 16384 as usize);
    const loaded: LocalChangeList = try local_change_file_read(&arena, "build/local-change-replace/local-change.hgi");

    try expect(loaded.len == 2 as usize);
    try expect(loaded.ptr[0].status == ChangeStatus.Materialized);
    try expect(loaded.ptr[1].status == ChangeStatus.Modified);
    try expect(hash32_compare(&loaded.ptr[1].working_hash, &update.working_hash) == 0);
    try expect(loaded.ptr[1].last_seen_inode == 330u64);
    try expect(loaded.ptr[1].last_seen_logical_size == 55u64);
    try expect(loaded.ptr[1].last_seen_file_mode == 33261u32);
    try expect(loaded.ptr[1].watcher_seq == 7u64);
    try expect(loaded.ptr[1].reconcile_epoch == 8u64);
}

export fn main() i32 {
    test_suite_begin("HyperGit Local Change File Tests");
    run_test("local change file roundtrip", test_local_change_file_roundtrip);
    run_test("local change file roundtrip above legacy size limit", test_local_change_file_roundtrip_above_legacy_size_limit);
    run_test("local change file replace existing preserves counters", test_local_change_file_replace_existing_preserves_counters);
    return test_suite_end();
}
