fn literal_bytes(text: &const byte) &[byte] {
    return (text as &byte)[0: strlen(text)];
}

fn read_file_bytes(arena: &Arena, path: &const byte) !&[byte] {
    var st: Stat = Stat{};
    try expect(stat(path, &st) == 0);
    const size: usize = st.st_size as usize;
    const raw: &byte = arena_alloc(arena, size) as &byte;
    try expect(raw != null);
    const out: &[byte] = raw[0: size];
    const stream: &FILE = fopen(path, "r");
    try expect(stream != null);
    defer {
        _ = fclose(stream);
    }
    try expect(fread(out.ptr, 1 as usize, size, stream) == size);
    return out;
}

fn write_file_bytes(path: &const byte, bytes: &[byte]) !void {
    const stream: &FILE = fopen(path, "w");
    try expect(stream != null);
    defer {
        _ = fclose(stream);
    }
    if bytes.len > 0 as usize {
        try expect(fwrite(bytes.ptr as &const byte, 1 as usize, bytes.len, stream) == bytes.len);
    }
}

fn trim_newline(slice: &[byte]) &[byte] {
    if slice.len > 0 as usize && slice.ptr[slice.len - 1 as usize] == '\n' as byte {
        return slice.ptr[0: slice.len - 1 as usize];
    }
    return slice;
}

fn expect_byte_slice_eq(actual: &[byte], expected: &[byte]) !void {
    try expect(actual.len == expected.len);
    var i: usize = 0 as usize;
    while i < actual.len {
        try expect(actual.ptr[i] == expected.ptr[i]);
        i = i + 1 as usize;
    }
}

fn build_chunked_blob_payload(arena: &Arena, chunk_store: &ChunkStore, logical: &[byte]) !ChunkedBlobPayload {
    const chunks: LargeChunkList = try fixed_chunk_bytes(arena, logical, 4u32);
    var parts_raw: [ChunkedBlobPart: 3] = [];
    var i: usize = 0 as usize;
    while i < chunks.len {
        const chunk: &LargeChunk = &chunks.ptr[i];
        const hashes: ChunkHashes = try chunk_hash_plain(arena, chunk.bytes.ptr[0: chunk.bytes.len]);
        const stored: ChunkStorePutResult = try chunk_store_put(chunk_store, chunk.bytes.ptr[0: chunk.bytes.len]);
        parts_raw[i] = chunked_blob_part_from_chunk(chunk, &hashes, &stored, StorageTier.Hot);
        i = i + 1 as usize;
    }
    const parts: ChunkedBlobPartList = chunked_blob_part_list_from_slice(parts_raw[0: chunks.len]);
    return try chunked_blob_payload_repository_default(arena, logical, FileType.Binary, ChunkingStrategy.Fixed, parts);
}

fn test_git_loose_blob_reads_and_imports_blob() !void {
    try expect(system("rm -rf build/git-interop-loose && mkdir -p build/git-interop-loose/repo build/git-interop-loose/hgit/objects/loose && cd build/git-interop-loose/repo && git init >/dev/null 2>&1 && printf hello-git > hello.txt && git hash-object -w hello.txt > ../oid.txt") == 0);

    var arena_buf: [byte: 1048576] = [];
    var arena: Arena = Arena{ buffer: &arena_buf[0], size: 0, used: 0 };
    arena_init(&arena, &arena_buf[0], 1048576 as usize);

    const oid_file: &[byte] = try read_file_bytes(&arena, "build/git-interop-loose/oid.txt");
    const oid_hex: &[byte] = trim_newline(oid_file);
    const blob: GitLooseBlob = try git_read_loose_blob(&arena, literal_bytes("build/git-interop-loose/repo/.git"), oid_hex);
    try expect(blob.oid_hex.len == 40 as usize);
    try expect_byte_slice_eq(blob.content.ptr[0: blob.content.len], literal_bytes("hello-git"));

    const store: LooseObjectStore = try loose_store_open("build/git-interop-loose/hgit/objects/loose");
    const object_id: ObjectId = try git_import_loose_blob_as_small_blob(&arena, &store, literal_bytes("build/git-interop-loose/repo/.git"), oid_hex);
    try expect(try store.has(object_id));

    var read_offset: usize = 0 as usize;
    const object_bytes: ObjectBytes = try store.get(object_id, &arena);
    const payload: SmallBlobPayload = try decode_small_blob_object(object_bytes.bytes.ptr[0: object_bytes.bytes.len], &read_offset);
    try expect(read_offset == object_bytes.bytes.len);
    try expect_byte_slice_eq(payload.payload.ptr[0: payload.payload.len], literal_bytes("hello-git"));
}

fn test_git_packed_delta_blob_reads_and_imports_blob() !void {
    try expect(system("rm -rf build/git-interop-packed && mkdir -p build/git-interop-packed/repo build/git-interop-packed/hgit/objects/loose && cd build/git-interop-packed/repo && git init >/dev/null 2>&1 && python3 -c 'from pathlib import Path; Path(\"base.txt\").write_text(\"A\" * 65536 + \"tail-a\\n\"); Path(\"variant.txt\").write_text(\"A\" * 65536 + \"tail-b\\n\")' && git add base.txt variant.txt >/dev/null 2>&1 && GIT_AUTHOR_DATE='1700000400 +0000' GIT_COMMITTER_DATE='1700000401 +0000' git -c user.name=Pack -c user.email=pack@example.com commit -m pack >/dev/null 2>&1 && git gc --aggressive --prune=now >/dev/null 2>&1 && git verify-pack -v .git/objects/pack/*.idx | awk '$2 == \"blob\" && NF == 7 && $6 ~ /^[1-9][0-9]*$/ && $7 ~ /^[0-9a-f]{40}$/ { print $1; exit }' > ../oid.txt && test -s ../oid.txt && oid=$(tr -d '\\n' < ../oid.txt) && git cat-file -p \"$oid\" > ../blob.txt") == 0);

    var arena_buf: [byte: 1048576] = [];
    var arena: Arena = Arena{ buffer: &arena_buf[0], size: 0, used: 0 };
    arena_init(&arena, &arena_buf[0], 1048576 as usize);

    const oid_file: &[byte] = try read_file_bytes(&arena, "build/git-interop-packed/oid.txt");
    const oid_hex: &[byte] = trim_newline(oid_file);
    const expected: &[byte] = try read_file_bytes(&arena, "build/git-interop-packed/blob.txt");
    const expected_hash: Hash32 = small_blob_content_hash(expected);
    const blob: GitLooseBlob = try git_read_loose_blob(&arena, literal_bytes("build/git-interop-packed/repo/.git"), oid_hex);
    try expect(blob.oid_hex.len == 40 as usize);
    try expect(blob.content.len == expected.len);
    const blob_hash: Hash32 = small_blob_content_hash(blob.content.ptr[0: blob.content.len]);
    try expect(hash32_compare(&blob_hash, &expected_hash) == 0);
    try expect(blob.content.ptr[0] == expected.ptr[0]);
    try expect(blob.content.ptr[blob.content.len - 1 as usize] == expected.ptr[expected.len - 1 as usize]);

    const store: LooseObjectStore = try loose_store_open("build/git-interop-packed/hgit/objects/loose");
    const object_id: ObjectId = try git_import_loose_blob_as_small_blob(&arena, &store, literal_bytes("build/git-interop-packed/repo/.git"), oid_hex);
    try expect(try store.has(object_id));

    var read_offset: usize = 0 as usize;
    const object_bytes: ObjectBytes = try store.get(object_id, &arena);
    const payload: SmallBlobPayload = try decode_small_blob_object(object_bytes.bytes.ptr[0: object_bytes.bytes.len], &read_offset);
    try expect(read_offset == object_bytes.bytes.len);
    try expect(payload.logical_size == expected.len as u64);
    try expect(payload.payload.len == expected.len);
    const payload_hash: Hash32 = small_blob_content_hash(payload.payload.ptr[0: payload.payload.len]);
    try expect(hash32_compare(&payload_hash, &expected_hash) == 0);
    try expect(payload.payload.ptr[0] == expected.ptr[0]);
    try expect(payload.payload.ptr[payload.payload.len - 1 as usize] == expected.ptr[expected.len - 1 as usize]);
}

