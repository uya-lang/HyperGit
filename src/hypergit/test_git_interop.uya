fn test_git_tree_to_manifest_imports_paths_and_modes() !void {
    try expect(system("rm -rf build/git-interop-tree && mkdir -p build/git-interop-tree/repo build/git-interop-tree/hgit/objects/loose && cd build/git-interop-tree/repo && git init >/dev/null 2>&1 && mkdir -p src && printf tree-main > src/main.txt && printf '#!/bin/sh\\necho hi\\n' > run.sh && chmod +x run.sh && git add src/main.txt run.sh >/dev/null 2>&1 && git write-tree > ../tree.txt") == 0);

    var arena_buf: [byte: 65536] = [];
    var arena: Arena = Arena{ buffer: &arena_buf[0], size: 0, used: 0 };
    arena_init(&arena, &arena_buf[0], 65536 as usize);

    const tree_file: &[byte] = try read_file_bytes(&arena, "build/git-interop-tree/tree.txt");
    const tree_hex: &[byte] = trim_newline(tree_file);
    const store: LooseObjectStore = try loose_store_open("build/git-interop-tree/hgit/objects/loose");

    const entries: GitTreeEntryList = try git_tree_to_manifest_entries(&arena, &store, literal_bytes("build/git-interop-tree/repo/.git"), tree_hex);
    try expect(entries.len == 2 as usize);
    try expect(entries.ptr[0].kind == EntryKind.Executable || entries.ptr[1].kind == EntryKind.Executable);
    try expect_byte_slice_eq(entries.ptr[0].path.ptr[0: entries.ptr[0].path.len], literal_bytes("run.sh"));
    try expect_byte_slice_eq(entries.ptr[1].path.ptr[0: entries.ptr[1].path.len], literal_bytes("src/main.txt"));

    const manifest_id: ManifestId = try git_tree_to_manifest(&arena, &store, literal_bytes("build/git-interop-tree/repo/.git"), tree_hex);
    try expect(try store.has(manifest_id.id));
}

fn test_git_tree_to_manifest_roundtrips_submodule_entry() !void {
    try expect(system("rm -rf build/git-interop-submodule && mkdir -p build/git-interop-submodule/sub build/git-interop-submodule/repo build/git-interop-submodule/export build/git-interop-submodule/hgit/objects/loose && cd build/git-interop-submodule/sub && git init >/dev/null 2>&1 && printf sub > child.txt && git add child.txt >/dev/null 2>&1 && GIT_AUTHOR_DATE='1700000500 +0000' GIT_COMMITTER_DATE='1700000501 +0000' git -c user.name=Sub -c user.email=sub@example.com commit -m sub >/dev/null 2>&1 && git rev-parse HEAD > ../sub-commit.txt && cd ../repo && git init >/dev/null 2>&1 && sub_commit=$(tr -d '\\n' < ../sub-commit.txt) && git update-index --add --cacheinfo 160000,\"$sub_commit\",deps/mod >/dev/null 2>&1 && git write-tree > ../tree.txt && cd ../export && git init >/dev/null 2>&1") == 0);

    var arena_buf: [byte: 65536] = [];
    var arena: Arena = Arena{ buffer: &arena_buf[0], size: 0, used: 0 };
    arena_init(&arena, &arena_buf[0], 65536 as usize);

    const tree_file: &[byte] = try read_file_bytes(&arena, "build/git-interop-submodule/tree.txt");
    const tree_hex: &[byte] = trim_newline(tree_file);
    const store: LooseObjectStore = try loose_store_open("build/git-interop-submodule/hgit/objects/loose");
    const entries: GitTreeEntryList = try git_tree_to_manifest_entries(&arena, &store, literal_bytes("build/git-interop-submodule/repo/.git"), tree_hex);
    try expect(entries.len == 1 as usize);
    try expect_byte_slice_eq(entries.ptr[0].path.ptr[0: entries.ptr[0].path.len], literal_bytes("deps/mod"));
    try expect(entries.ptr[0].kind == EntryKind.File);
    try expect(entries.ptr[0].file_mode == 0o160000u32);
    try expect(entries.ptr[0].logical_size == 40u64);

    var read_offset: usize = 0 as usize;
    const object_bytes: ObjectBytes = try store.get(entries.ptr[0].object_id, &arena);
    const payload: SmallBlobPayload = try decode_small_blob_object(object_bytes.bytes.ptr[0: object_bytes.bytes.len], &read_offset);
    try expect(read_offset == object_bytes.bytes.len);

    const sub_commit_file: &[byte] = try read_file_bytes(&arena, "build/git-interop-submodule/sub-commit.txt");
    const sub_commit_hex: &[byte] = trim_newline(sub_commit_file);
    try expect_byte_slice_eq(payload.payload.ptr[0: payload.payload.len], sub_commit_hex);

    const manifest_id: ManifestId = try git_tree_to_manifest(&arena, &store, literal_bytes("build/git-interop-submodule/repo/.git"), tree_hex);
    const exported: GitTreeExport = try hypergit_manifest_to_git_tree(
        &arena,
        &store,
        literal_bytes("build/git-interop-submodule/export/.git"),
        &manifest_id,
    );
    try expect(exported.entry_count == 1 as usize);
    try write_file_bytes("build/git-interop-submodule/exported-tree.txt", exported.tree_hex.ptr[0: exported.tree_hex.len]);
    try expect(system("cd build/git-interop-submodule/export && tree=$(cat ../exported-tree.txt) && git ls-tree -r \"$tree\" > ../ls-tree.txt") == 0);
    const ls_tree: &[byte] = try read_file_bytes(&arena, "build/git-interop-submodule/ls-tree.txt");
    try expect(ls_tree.len > 0 as usize);
    try expect_byte_slice_eq(ls_tree[0: 14], literal_bytes("160000 commit "));
    try expect_byte_slice_eq(ls_tree[14: 40], sub_commit_hex);
    try expect_byte_slice_eq(ls_tree[54: ls_tree.len - 54], literal_bytes("\tdeps/mod\n"));
}

fn test_git_commit_to_hypergit_commit_imports_history() !void {
    try expect(system("rm -rf build/git-interop-commit && mkdir -p build/git-interop-commit/repo build/git-interop-commit/hgit/objects/loose && cd build/git-interop-commit/repo && git init >/dev/null 2>&1 && printf one > file.txt && git add file.txt >/dev/null 2>&1 && GIT_AUTHOR_DATE='1700000000 +0000' GIT_COMMITTER_DATE='1700000001 +0000' git -c user.name=Alice -c user.email=alice@example.com commit -m first >/dev/null 2>&1 && printf two > file.txt && mkdir -p src && printf child > src/child.txt && git add file.txt src/child.txt >/dev/null 2>&1 && GIT_AUTHOR_DATE='1700000100 +0000' GIT_COMMITTER_DATE='1700000101 +0000' git -c user.name=Bob -c user.email=bob@example.com commit -m second >/dev/null 2>&1 && git rev-parse HEAD > ../head.txt") == 0);

    var arena_buf: [byte: 131072] = [];
    var arena: Arena = Arena{ buffer: &arena_buf[0], size: 0, used: 0 };
    arena_init(&arena, &arena_buf[0], 131072 as usize);

    const head_file: &[byte] = try read_file_bytes(&arena, "build/git-interop-commit/head.txt");
    const head_hex: &[byte] = trim_newline(head_file);
    const store: LooseObjectStore = try loose_store_open("build/git-interop-commit/hgit/objects/loose");

    const imported: GitCommitImport = try git_import_commit(&arena, &store, literal_bytes("build/git-interop-commit/repo/.git"), head_hex);
    try expect(imported.generation == 2u64);
    try expect(try store.has(imported.commit_id.id));
    try expect(try store.has(imported.manifest_root.id));

    var read_arena_buf: [byte: 65536] = [];
    var read_arena: Arena = Arena{ buffer: &read_arena_buf[0], size: 0, used: 0 };
    arena_init(&read_arena, &read_arena_buf[0], 65536 as usize);

    const object_bytes: ObjectBytes = try store.get(imported.commit_id.id, &read_arena);
    var offset: usize = 0 as usize;
    const payload: CommitPayload = try decode_commit_object(&read_arena, object_bytes.bytes.ptr[0: object_bytes.bytes.len], &offset);
    try expect(offset == object_bytes.bytes.len);
    try expect(payload.parents.len == 1 as usize);
    const parent_id: CommitId = payload.parents.ptr[0];
    try expect(try store.has(parent_id.id));
    try expect(commit_id_compare(&parent_id, &imported.commit_id) != 0);
    try expect(manifest_id_compare(&payload.manifest_root, &imported.manifest_root) == 0);
    try expect(payload.generation == 2u64);
    try expect(payload.timestamp_ms == 1700000100000i64);
    try expect_byte_slice_eq(payload.author.name.ptr[0: payload.author.name.len], literal_bytes("Bob"));
    try expect_byte_slice_eq(payload.author.email.ptr[0: payload.author.email.len], literal_bytes("bob@example.com"));
    try expect_byte_slice_eq(payload.committer.name.ptr[0: payload.committer.name.len], literal_bytes("Bob"));
    try expect_byte_slice_eq(payload.message.ptr[0: payload.message.len], literal_bytes("second\n"));
}

fn test_git_tagged_commit_imports_referenced_commit() !void {
    try expect(system("rm -rf build/git-interop-tag-commit && mkdir -p build/git-interop-tag-commit/repo build/git-interop-tag-commit/hgit/objects/loose && cd build/git-interop-tag-commit/repo && git init >/dev/null 2>&1 && printf one > file.txt && git add file.txt >/dev/null 2>&1 && GIT_AUTHOR_DATE='1700000600 +0000' GIT_COMMITTER_DATE='1700000601 +0000' git -c user.name=Tag -c user.email=tag@example.com commit -m tagged >/dev/null 2>&1 && git -c user.name=Tag -c user.email=tag@example.com tag -a release-tag -m release-tag >/dev/null 2>&1 && git rev-parse release-tag^{tag} > ../tag.txt") == 0);

    var arena_buf: [byte: 131072] = [];
    var arena: Arena = Arena{ buffer: &arena_buf[0], size: 0, used: 0 };
