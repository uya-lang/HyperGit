    const tag_file: &[byte] = try read_file_bytes(&arena, "build/git-interop-tag-commit/tag.txt");
    const tag_hex: &[byte] = trim_newline(tag_file);
    const store: LooseObjectStore = try loose_store_open("build/git-interop-tag-commit/hgit/objects/loose");
    const imported: GitCommitImport = try git_import_commit(&arena, &store, literal_bytes("build/git-interop-tag-commit/repo/.git"), tag_hex);
    try expect(imported.generation == 1u64);

    const object_bytes: ObjectBytes = try store.get(imported.commit_id.id, &arena);
