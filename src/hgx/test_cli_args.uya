use std.runtime.entry;
use std.testing.expect;
use std.testing.assert_eq_i32;
use std.testing.test_suite_begin;
use std.testing.test_suite_end;
use std.testing.run_test;
use std.string.strcmp;

use cli.DispatchAction;
use cli.DispatchPlan;
use cli.EXIT_NOT_IMPLEMENTED;
use cli.EXIT_OK;
use cli.EXIT_USAGE_ERROR;
use cli.plan_from_first_arg;

fn test_default_help() !void {
    const plan: DispatchPlan = plan_from_first_arg(1, null);
    try expect(plan.action == DispatchAction.Help);
    try assert_eq_i32(plan.exit_code, EXIT_OK);
    try expect(plan.subject == null);
}

fn test_help_flag() !void {
    const plan: DispatchPlan = plan_from_first_arg(2, "--help");
    try expect(plan.action == DispatchAction.Help);
    try assert_eq_i32(plan.exit_code, EXIT_OK);
}

fn test_version_flag() !void {
    const plan: DispatchPlan = plan_from_first_arg(2, "-v");
    try expect(plan.action == DispatchAction.Version);
    try assert_eq_i32(plan.exit_code, EXIT_OK);
}

fn test_doctor_placeholder() !void {
    const plan: DispatchPlan = plan_from_first_arg(2, "doctor");
    try expect(plan.action == DispatchAction.Doctor);
    try assert_eq_i32(plan.exit_code, EXIT_NOT_IMPLEMENTED);
}

fn test_status_command() !void {
    const plan: DispatchPlan = plan_from_first_arg(2, "status");
    try expect(plan.action == DispatchAction.Status);
    try assert_eq_i32(plan.exit_code, EXIT_OK);
}

fn test_fetch_command() !void {
    const plan: DispatchPlan = plan_from_first_arg(2, "fetch");
    try expect(plan.action == DispatchAction.Fetch);
    try assert_eq_i32(plan.exit_code, EXIT_OK);
}

fn test_push_command() !void {
    const plan: DispatchPlan = plan_from_first_arg(2, "push");
    try expect(plan.action == DispatchAction.Push);
    try assert_eq_i32(plan.exit_code, EXIT_OK);
}

fn test_diff_command() !void {
    const plan: DispatchPlan = plan_from_first_arg(2, "diff");
    try expect(plan.action == DispatchAction.Diff);
    try assert_eq_i32(plan.exit_code, EXIT_OK);
}

fn test_checkout_command() !void {
    const plan: DispatchPlan = plan_from_first_arg(2, "checkout");
    try expect(plan.action == DispatchAction.Checkout);
    try assert_eq_i32(plan.exit_code, EXIT_OK);
}

fn test_hydrate_command() !void {
    const plan: DispatchPlan = plan_from_first_arg(2, "hydrate");
    try expect(plan.action == DispatchAction.Hydrate);
    try assert_eq_i32(plan.exit_code, EXIT_OK);
}

fn test_dehydrate_command() !void {
    const plan: DispatchPlan = plan_from_first_arg(2, "dehydrate");
    try expect(plan.action == DispatchAction.Dehydrate);
    try assert_eq_i32(plan.exit_code, EXIT_OK);
}

fn test_sparse_command() !void {
    const plan: DispatchPlan = plan_from_first_arg(2, "sparse");
    try expect(plan.action == DispatchAction.Sparse);
    try assert_eq_i32(plan.exit_code, EXIT_OK);
}

fn test_add_command() !void {
    const plan: DispatchPlan = plan_from_first_arg(2, "add");
    try expect(plan.action == DispatchAction.Add);
    try assert_eq_i32(plan.exit_code, EXIT_OK);
}

fn test_commit_command() !void {
    const plan: DispatchPlan = plan_from_first_arg(2, "commit");
    try expect(plan.action == DispatchAction.Commit);
    try assert_eq_i32(plan.exit_code, EXIT_OK);
}

fn test_log_command() !void {
    const plan: DispatchPlan = plan_from_first_arg(2, "log");
    try expect(plan.action == DispatchAction.Log);
    try assert_eq_i32(plan.exit_code, EXIT_OK);
}

fn test_init_placeholder() !void {
    const plan: DispatchPlan = plan_from_first_arg(2, "init");
    try expect(plan.action == DispatchAction.Init);
    try assert_eq_i32(plan.exit_code, EXIT_NOT_IMPLEMENTED);
}

fn test_unknown_command() !void {
    const plan: DispatchPlan = plan_from_first_arg(2, "bogus");
    try expect(plan.action == DispatchAction.Unknown);
    try assert_eq_i32(plan.exit_code, EXIT_USAGE_ERROR);
    try expect(strcmp(plan.subject as &const byte, "bogus") == 0);
}

export fn main() i32 {
    test_suite_begin("CLI Parse Tests");
    run_test("default help", test_default_help);
    run_test("help flag", test_help_flag);
    run_test("version flag", test_version_flag);
    run_test("doctor placeholder", test_doctor_placeholder);
    run_test("status command", test_status_command);
    run_test("fetch command", test_fetch_command);
    run_test("push command", test_push_command);
    run_test("diff command", test_diff_command);
    run_test("checkout command", test_checkout_command);
    run_test("hydrate command", test_hydrate_command);
    run_test("dehydrate command", test_dehydrate_command);
    run_test("sparse command", test_sparse_command);
    run_test("add command", test_add_command);
    run_test("commit command", test_commit_command);
    run_test("log command", test_log_command);
    run_test("init placeholder", test_init_placeholder);
    run_test("unknown command", test_unknown_command);
    return test_suite_end();
}
