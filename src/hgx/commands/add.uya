const ADD_ARENA_BYTES: usize = 1073741824 as usize;
const ADD_PATHSPEC_ARENA_BYTES: usize = 65536 as usize;
const ADD_PATH_MAX: usize = 4096;
const ADD_PARALLEL_WORKERS_DEFAULT: i32 = 4;
const ADD_PARALLEL_MAX_WORKERS: usize = 1024 as usize;
const ADD_PARALLEL_DEFAULT_MAX_WORKERS: i32 = 20;
const ADD_PREPARE_FANOUT_MIN_FILES: usize = 1024 as usize;
const ADD_PARALLEL_BATCH_MAX_FILES: usize = 65536 as usize;
const ADD_SMALL_BLOB_FAST_MAX_BYTES: usize = 4096 as usize;
const ADD_SMALL_BLOB_FAST_PAYLOAD_BYTES: usize = ADD_SMALL_BLOB_FAST_MAX_BYTES + 64 as usize;
const ADD_SMALL_BLOB_FAST_HASH_BYTES: usize = ADD_SMALL_BLOB_FAST_PAYLOAD_BYTES + 128 as usize;
const ADD_PROGRESS_MIN_FILES: usize = 4096 as usize;
const ADD_PROGRESS_INTERVAL_FILES: usize = 4096 as usize;
const ADD_PROGRESS_MIN_BYTES: u64 = 1073741824u64;
// Small-file first-add is allocation/metadata-bound, not CPU-bound: each object is
// a malloc + open(O_CREAT|O_EXCL)+write+rename, and the process allocator serializes
// malloc/free across threads. Spreading these across workers turns that serialization
// into heavy lock contention instead of speeding anything up. Measured on a 1M-file
// repo (avg ~1.6KB), 20-worker add was ~9x SLOWER than serial. Hashing only begins to
// dominate the per-file cost once files reach tens of KB, so below that average we keep
// the bulk small-blob path serial; larger small blobs and explicit worker requests still
// parallelize.
const ADD_PARALLEL_TINY_SMALL_BLOB_MIN_FILES: usize = 4096 as usize;
const ADD_PARALLEL_TINY_SMALL_BLOB_AVG_BYTES: u64 = 65536u64;
const ADD_PREPARE_SMALL_PERMISSION: usize = 1 as usize;
const ADD_PREPARE_SMALL_READ_FAILED: usize = 2 as usize;
const ADD_PREPARE_SMALL_ALLOC_FAILED: usize = 3 as usize;
const ADD_PREPARE_SMALL_ENCODE_FAILED: usize = 4 as usize;
const ADD_PREPARE_SMALL_HASH_FAILED: usize = 5 as usize;
const ADD_STORE_OBJECT_PERMISSION: usize = 6 as usize;
const ADD_STORE_OBJECT_UNPROCESSABLE: usize = 7 as usize;
const ADD_STORE_OBJECT_FATAL: usize = 8 as usize;
const ADD_FILE_PROCESS_PENDING: usize = 0 as usize;
const ADD_FILE_PROCESS_STORED: usize = 1 as usize;
const ADD_FILE_PROCESS_SKIP_PERMISSION: usize = 2 as usize;
const ADD_FILE_PROCESS_SKIP_UNPROCESSABLE: usize = 3 as usize;
const ADD_WORKER_SLOT_IDLE: i32 = 0;
const ADD_WORKER_SLOT_ASSIGNED: i32 = 1;
const ADD_WORKER_SLOT_COMPLETED: i32 = 2;
const ADD_WORKER_SLOT_STOP: i32 = 3;

