const ADD_ARENA_BYTES: usize = 268435456 as usize;
const ADD_PATHSPEC_ARENA_BYTES: usize = 65536 as usize;
const ADD_PATH_MAX: usize = 4096;
const ADD_PARALLEL_WORKERS_DEFAULT: i32 = 2;
const ADD_PARALLEL_MAX_WORKERS: usize = 32 as usize;
const ADD_PARALLEL_CPU_MASK_BYTES: usize = 128 as usize;
// Keep `hgx add` under roughly 200% CPU by capping to two concurrent workers.
const ADD_PARALLEL_ASYNC_MAX_INFLIGHT: usize = 2 as usize;
const ADD_PROGRESS_MIN_FILES: usize = 4096 as usize;
const ADD_PROGRESS_INTERVAL_FILES: usize = 4096 as usize;
const ADD_PROGRESS_MIN_BYTES: u64 = 1073741824u64;
const ADD_PREPARE_SMALL_PERMISSION: usize = 1 as usize;
const ADD_PREPARE_SMALL_READ_FAILED: usize = 2 as usize;
const ADD_PREPARE_SMALL_ALLOC_FAILED: usize = 3 as usize;
const ADD_PREPARE_SMALL_ENCODE_FAILED: usize = 4 as usize;
const ADD_PREPARE_SMALL_HASH_FAILED: usize = 5 as usize;
const ADD_STORE_OBJECT_PERMISSION: usize = 6 as usize;
const ADD_STORE_OBJECT_UNPROCESSABLE: usize = 7 as usize;
const ADD_STORE_OBJECT_FATAL: usize = 8 as usize;
const ADD_WORKER_SLOT_IDLE: i32 = 0;
const ADD_WORKER_SLOT_ASSIGNED: i32 = 1;
const ADD_WORKER_SLOT_COMPLETED: i32 = 2;
const ADD_WORKER_SLOT_STOP: i32 = 3;

