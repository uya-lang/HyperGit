const DIFF_ARENA_BYTES: usize = 2147483648 as usize;
const DIFF_PATHSPEC_ARENA_BYTES: usize = 1048576 as usize;
const DIFF_PARALLEL_MANIFEST_WORKERS_DEFAULT: i32 = 2;
const DIFF_FILE_MODE_EXEC_BITS: u32 = 73u32;
const DIFF_FILE_MODE_TYPE_MASK: u32 = 61440u32;
const DIFF_FILE_MODE_REGULAR: u32 = 32768u32;
const DIFF_FILE_MODE_SYMLINK: u32 = 40960u32;
const DIFF_MODE_FILE: u32 = 0o100644u32;
const DIFF_MODE_EXECUTABLE: u32 = 0o100755u32;
const DIFF_MODE_SYMLINK: u32 = 0o120000u32;

