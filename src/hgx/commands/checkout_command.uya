use std.mem.arena.arena_init;
use std.runtime.get_argc;
use std.runtime.get_argv;
use std.string.strcmp;
use std.string.strlen;
use std.time.now_ms;

use libc.free;
use libc.fprintf;
use libc.malloc;
use libc.stderr;
use cli.EXIT_OK;
use cli.EXIT_RUNTIME_ERROR;
use cli.EXIT_USAGE_ERROR;
use commands.audit_support.AuditSummary;
use commands.audit_support.audit_commit_id_text;
use commands.audit_support.audit_cstr_byte_list;
use commands.audit_support.audit_policy_profile_default;
use commands.audit_support.audit_repo_event_append;
use commands.audit_support.audit_summary_from_manifest_diff;
use commands.checkout.CHECKOUT_DIRTY_TEXT;
use commands.checkout.CHECKOUT_FAILURE_TEXT;
use commands.checkout.CHECKOUT_NO_COMMITS_TEXT;
use commands.checkout.CHECKOUT_NOT_REPO_TEXT;
use commands.checkout.CHECKOUT_PERMISSION_TEXT;
use commands.checkout.CHECKOUT_USAGE_TEXT;
use commands.checkout.checkout_apply_plan;
use commands.checkout.checkout_current_local_changes;
use commands.checkout.checkout_current_sparse_profile;
use commands.checkout.checkout_current_state;
use commands.checkout.checkout_load_stage_snapshot;
use commands.checkout.checkout_manifest_inputs_from_commit;
use commands.checkout.checkout_restore_plan_build;
use commands.checkout.checkout_state_has_base_commit;
use commands.checkout.checkout_sync_virtual_state;
use core.audit_log.AuditLogEvent;
use core.audit_log.AuditLogEventKind;
use core.ids.CommitId;
use core.ids.HASH32_HEX_BYTES;
use core.ids.commit_id_decode_hex;
use core.path_policy.PathPolicyProfile;
use manifest.trie.ManifestLeafInputList;
use object.types.ByteList;
use store.head_ref.repo_head_ref_exists;
use store.head_ref.repo_read_head_commit;
use store.loose_store.LooseObjectStore;
use store.loose_store.loose_store_open_packed;
use store.repo_layout.HGIT_OBJECTS_LOOSE_REL;
use store.repo_layout.HGIT_OBJECTS_PACKS_REL;
use store.repo_layout.RepoConfig;
use store.repo_layout.RepoPath;
use store.repo_layout.repo_find_root_from_cwd;
use store.repo_layout.repo_path_cstr;
use store.repo_layout.repo_path_join_literal;
use store.repo_layout.repo_read_config;
